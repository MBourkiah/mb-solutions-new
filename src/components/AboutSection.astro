---
// AboutSection — two-column editorial, new design system
---

<style>
  .about {
    background: var(--bg);
    padding: 6rem 5%;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ─── Visual ───────────────────── */
  .about-visual {
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .about-visual::before {
    content: '';
    position: absolute; inset: -24px;
    background: radial-gradient(ellipse at 50% 50%, rgba(127,119,221,0.1) 0%, transparent 65%);
    pointer-events: none;
  }
  .about-avatar-wrap {
    position: relative; z-index: 1;
    width: 260px; height: 260px;
    border-radius: var(--r-xl);
    background: var(--surface-2);
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .about-avatar-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(127,119,221,0.12) 0%, rgba(45,212,191,0.05) 100%);
  }
  .about-avatar-icon {
    position: relative; z-index: 1;
    width: 80px; height: 80px;
    border-radius: 50%;
    background: rgba(127,119,221,0.15);
    border: 1px solid rgba(127,119,221,0.25);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
  }
  .about-badge {
    position: absolute;
    bottom: -16px; right: -16px;
    background: var(--surface-2);
    border: 1px solid var(--border-accent);
    border-radius: var(--r-md);
    padding: 12px 16px;
    display: flex; flex-direction: column; gap: 2px;
  }
  .about-badge-val {
    font-size: 1.375rem; font-weight: 700; color: var(--accent);
    font-family: 'Poppins', sans-serif; line-height: 1;
  }
  .about-badge-label { font-size: 11px; color: var(--text-dim); letter-spacing: 0.04em; }

  /* ─── Content ──────────────────── */
  .about-headline {
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 700; letter-spacing: -0.025em; color: var(--text);
    line-height: 1.2; margin: 0 0 1.25rem;
  }
  .about-body {
    font-size: 1rem; color: var(--text-muted); line-height: 1.8;
    margin: 0 0 2rem;
  }
  .about-facts { display: flex; flex-direction: column; gap: 0; margin-bottom: 2rem; }
  .about-fact {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .about-fact:first-child { border-top: 1px solid var(--border); }
  .about-fact-icon {
    width: 32px; height: 32px; border-radius: var(--r-sm);
    background: rgba(127,119,221,0.08);
    border: 1px solid rgba(127,119,221,0.14);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); flex-shrink: 0; margin-top: 2px;
  }
  .about-fact-text { display: flex; flex-direction: column; gap: 2px; }
  .about-fact-title {
    font-size: 0.875rem; font-weight: 600; color: var(--text);
    font-family: 'Poppins', sans-serif;
  }
  .about-fact-sub { font-size: 0.8125rem; color: var(--text-dim); line-height: 1.5; }

  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; gap: 3rem; }
    .about-visual { order: -1; }
    .about-avatar-wrap { width: 200px; height: 200px; }
  }
</style>

<section class="about" aria-labelledby="about-heading">
  <div class="section-inner">
    <div class="about-grid">

      <!-- Visual -->
      <div class="about-visual">
        <div class="about-avatar-wrap">
          <div class="about-avatar-bg" aria-hidden="true"></div>
          <div class="about-avatar-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
        </div>
        <div class="about-badge" aria-hidden="true">
          <span class="about-badge-val">5+</span>
          <span class="about-badge-label">Jahre Erfahrung</span>
        </div>
      </div>

      <!-- Text -->
      <div>
        <div class="eyebrow">
          <div class="eyebrow-line"></div>
          <span class="eyebrow-text">Über mich</span>
        </div>
        <h2 class="about-headline" id="about-heading">
          Ein Ansprechpartner.<br/>Null Overhead.
        </h2>
        <p class="about-body">
          Ich bin Maurice, Freelancer aus Köln. Ich helfe kleinen Unternehmen und Handwerksbetrieben,
          ihren digitalen Auftritt auf Vordermann zu bringen — ohne Agentur-Preise, ohne Warteschlange.
        </p>

        <div class="about-facts">
          <div class="about-fact stagger-reveal">
            <div class="about-fact-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="about-fact-text">
              <span class="about-fact-title">Köln-basiert</span>
              <span class="about-fact-sub">Persönliche Treffen möglich, deutschlandweite Betreuung remote.</span>
            </div>
          </div>
          <div class="about-fact stagger-reveal">
            <div class="about-fact-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            </div>
            <div class="about-fact-text">
              <span class="about-fact-title">Full-Stack-Ansatz</span>
              <span class="about-fact-sub">Design, Code und IT aus einer Hand — keine Reibungsverluste zwischen Teams.</span>
            </div>
          </div>
          <div class="about-fact stagger-reveal">
            <div class="about-fact-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <div class="about-fact-text">
              <span class="about-fact-title">Langfristige Betreuung</span>
              <span class="about-fact-sub">Kein Projekt-Dump — ich bleibe Ansprechpartner auch nach dem Launch.</span>
            </div>
          </div>
        </div>

        <a href="/ueber-mich" class="btn-outline">
          Mehr über mich
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
