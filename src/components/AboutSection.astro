---
const facts = [
  { val: '5+',  label: 'Jahre Erfahrung' },
  { val: '12+', label: 'Projekte' },
  { val: '48h', label: 'Antwortzeit' },
  { val: '1:1', label: 'Direktbetreuung' },
];
---

<style>
  .about { background: var(--bg-alt); padding: 6rem 5% 7rem; }
  .about-inner {
    max-width: 80rem; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 440px;
    gap: 5rem; align-items: center;
  }

  .about-h2 {
    font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800;
    letter-spacing: -0.04em; color: var(--text); line-height: 1.02; margin-bottom: 1.75rem;
  }
  .about-p {
    font-size: 1.0625rem; color: var(--text-2);
    line-height: 1.8; max-width: 52ch; margin-bottom: 1.375rem;
  }
  .about-p:last-of-type { margin-bottom: 2rem; }

  .about-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 14px; font-weight: 600; color: var(--accent);
    text-decoration: none; font-family: 'Outfit', sans-serif;
  }
  .about-link svg { transition: transform 150ms var(--ease-out); flex-shrink: 0; }
  @media (hover: hover) and (pointer: fine) {
    .about-link:hover svg { transform: translate(3px, -3px); }
  }

  .about-right { display: flex; flex-direction: column; gap: 16px; }

  .fact-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
  .fact-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);
    transition: transform 220ms var(--ease-out), box-shadow 220ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .fact-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  }
  /* Stagger fact cards when revealing */
  .fact-card:nth-child(1) { transition-delay: 0ms; }
  .fact-card:nth-child(2) { transition-delay: 70ms; }
  .fact-card:nth-child(3) { transition-delay: 140ms; }
  .fact-card:nth-child(4) { transition-delay: 210ms; }
  .fact-val {
    font-family: 'Outfit', sans-serif; font-size: 2.25rem; font-weight: 800;
    letter-spacing: -0.04em; color: var(--accent); line-height: 1;
    display: block; margin-bottom: 4px;
  }
  .fact-label { font-size: 12px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.07em; font-weight: 500; }

  .about-quote {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 1.75rem;
    box-shadow: var(--shadow-sm); position: relative;
  }
  .about-quote::before {
    content: '"'; position: absolute; top: 12px; right: 20px;
    font-family: 'Outfit', sans-serif; font-size: 5rem; font-weight: 800; line-height: 1;
    color: var(--accent-light); pointer-events: none;
  }
  .quote-text { font-size: 1rem; color: var(--text-2); line-height: 1.7; font-style: italic; margin-bottom: 1.25rem; }
  .quote-author { display: flex; align-items: center; gap: 10px; }
  .quote-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    background: var(--accent); color: white;
    font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .quote-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .quote-role { font-size: 11px; color: var(--text-3); }

  @media (max-width: 900px) {
    .about-inner { grid-template-columns: 1fr; gap: 3rem; }
    .about-right { order: -1; }
    .fact-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 599px) {
    .about { padding: 4rem 5% 4.5rem; }
  }
</style>

<section class="about" aria-labelledby="about-heading">
  <div class="about-inner">
    <div>
      <div class="eyebrow reveal">
        <span class="eyebrow-bar" aria-hidden="true"></span>
        Über mich
      </div>
      <h2 class="about-h2 reveal" id="about-heading">
        Technik mit<br/>Handschlag.
      </h2>
      <p class="about-p reveal">
        Ich bin Maurice Bourkiah — Webdesigner, Entwickler und
        IT-Berater aus Köln. Ich arbeite direkt mit meinen Kunden:
        keine Unterauftragnehmer, keine langen Kommunikationsketten.
      </p>
      <p class="about-p reveal">
        Was mich antreibt: Handwerksbetriebe und kleine Unternehmen
        verdienen denselben professionellen Webauftritt wie große Konzerne —
        ohne die großen Agentur-Budgets dafür zu brauchen.
      </p>
      <a href="/ueber-mich" class="about-link reveal">
        Mehr über mich
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="about-right">
      <div class="fact-grid">
        {facts.map(f => (
          <div class="fact-card reveal">
            <span class="fact-val">{f.val}</span>
            <span class="fact-label">{f.label}</span>
          </div>
        ))}
      </div>
      <div class="about-quote reveal">
        <blockquote>
          <p class="quote-text">
            "Maurice hat unsere Website in unter drei Wochen komplett neu aufgesetzt.
            Endlich sieht unser Auftritt so professionell aus wie unsere Arbeit."
          </p>
        </blockquote>
        <div class="quote-author">
          <div class="quote-avatar" aria-hidden="true">KS</div>
          <div>
            <div class="quote-name">Klaus S.</div>
            <div class="quote-role">Inhaber, Keller &amp; Söhne GmbH</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
