---
const trustPoints = [
  'Wirtschaftsinformatik, Universität Köln',
  'Persönliche Betreuung – kein Outsourcing',
];
---

<section class="bg-white py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text Column -->
      <div>
        <p class="text-primary font-medium tracking-wide uppercase text-sm mb-3">
          Über mich
        </p>
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">
          Technik trifft Wirtschaft.
        </h2>

        <div class="space-y-4 text-gray-500 leading-relaxed">
          <p>
            Ich bin [Name], Wirtschaftsinformatik-Student in Köln und Gründer
            von MB-Solutions.
          </p>
          <p>
            Was mich von klassischen Agenturen unterscheidet: Ich denke nicht
            nur in Code, sondern auch in Geschäftsmodellen. Deine Website soll
            nicht nur schön aussehen – sie soll dir Kunden bringen.
          </p>
          <p>
            Jedes Projekt betreue ich persönlich, von der ersten Idee bis zum
            Launch – und danach.
          </p>
        </div>

        <!-- Trust Points -->
        <ul class="mt-8 space-y-3">
          {trustPoints.map((point) => (
            <li class="flex items-start gap-3">
              <span
                class="mt-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-primary/10 shrink-0"
                aria-hidden="true"
              >
                <svg
                  class="w-3 h-3 text-primary"
                  viewBox="0 0 12 12"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 6l3 3 5-5" />
                </svg>
              </span>
              <span class="text-gray-700 font-medium text-sm">{point}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Visual / Photo Placeholder -->
      <div class="flex flex-col gap-3">
        <div
          class="w-full h-80 rounded-2xl bg-primary/10 flex items-center justify-center"
          aria-label="Foto-Platzhalter"
        >
          <div class="text-center">
            <p class="text-4xl mb-2" aria-hidden="true">📸</p>
            <p class="text-primary/40 font-medium text-sm">Dein Foto</p>
          </div>
        </div>
        <p class="text-xs text-gray-400 text-center leading-relaxed px-4">
          Professionelles Foto empfohlen – wirkt Wunder beim Vertrauen.
        </p>
      </div>

    </div>
  </div>
</section>
