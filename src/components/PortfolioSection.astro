---
const projects = [
  {
    title: 'Café Morgenrot',
    category: 'Webdesign',
    desc: 'Booking-Website mit Online-Reservierung für ein Kölner Café. Fokus auf Atmosphäre und Conversion.',
    tags: ['Astro', 'Tailwind CSS', 'Netlify Forms'],
    year: '2024',
    accent: '#D97706',
  },
  {
    title: 'Keller & Söhne GmbH',
    category: 'IT-Services + Branding',
    desc: 'Komplettes IT-Setup inkl. Google Workspace-Migration und neues Corporate Identity für ein Handwerksunternehmen.',
    tags: ['Google Workspace', 'Logo Design', 'CI-Manual'],
    year: '2024',
    accent: '#16A34A',
  },
  {
    title: 'Yogastudio Sonnenlicht',
    category: 'Webdesign',
    desc: 'Ruhige, minimalistische Website mit Kurskalender und Buchungsfunktion für ein Yoga-Studio in Köln-Nippes.',
    tags: ['Next.js', 'Framer Motion', 'Vercel'],
    year: '2023',
    accent: 'var(--accent)',
  },
];
---

<style>
  .portfolio { background: var(--bg); padding: 6rem 5% 7rem; }
  .portfolio-inner { max-width: 80rem; margin: 0 auto; }

  .portfolio-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 3.5rem; gap: 2rem; flex-wrap: wrap;
  }
  .portfolio-h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800; letter-spacing: -0.04em; color: var(--text); line-height: 1.0;
  }

  .portfolio-list { display: flex; flex-direction: column; gap: 2px; }

  .portfolio-item {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-xl); padding: 2rem 2.5rem;
    display: grid; grid-template-columns: 60px 1fr auto;
    gap: 0 2rem; align-items: center;
    text-decoration: none; color: inherit;
    transition: box-shadow 200ms var(--ease-out), transform 200ms var(--ease-out),
                border-color 200ms var(--ease-out);
    position: relative; overflow: hidden;
  }
  @media (hover: hover) and (pointer: fine) {
    .portfolio-item:hover {
      box-shadow: var(--shadow-md); transform: translateX(4px); border-color: var(--border-2);
    }
    .portfolio-item:hover .pf-arrow { transform: translateX(4px); }
    .portfolio-item:hover::before { opacity: 1; }
  }
  .portfolio-item::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--item-accent); opacity: 0; transition: opacity 200ms var(--ease-out);
    border-radius: var(--r-xl) var(--r-xl) 0 0;
  }

  .pf-num {
    font-family: 'Outfit', sans-serif; font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-3);
  }
  .pf-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .pf-cat { font-size: 11px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-3); }
  .pf-year {
    font-size: 11px; color: var(--text-3);
    padding: 1px 7px; border-radius: var(--r-full); border: 1px solid var(--border);
  }
  .pf-title {
    font-family: 'Outfit', sans-serif; font-size: 1.25rem; font-weight: 700;
    letter-spacing: -0.025em; color: var(--text); margin-bottom: 4px;
  }
  .pf-desc { font-size: 0.875rem; color: var(--text-2); line-height: 1.6; max-width: 62ch; }
  .pf-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
  .pf-tag {
    font-size: 11px; font-weight: 500; color: var(--text-3);
    background: var(--bg); border: 1px solid var(--border);
    padding: 2px 8px; border-radius: var(--r-full);
  }

  .pf-arrow {
    width: 36px; height: 36px; border-radius: var(--r-md);
    background: var(--bg-alt); border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-3); flex-shrink: 0;
    transition: transform 200ms var(--ease-out);
  }

  .portfolio-cta-row { display: flex; justify-content: center; margin-top: 3rem; }

  @media (max-width: 700px) {
    .portfolio-item { grid-template-columns: 1fr auto; }
    .pf-num { display: none; }
  }
  @media (max-width: 500px) {
    .portfolio-item { padding: 1.5rem; grid-template-columns: 1fr; }
    .pf-arrow { display: none; }
  }
</style>

<section class="portfolio" aria-labelledby="portfolio-heading">
  <div class="portfolio-inner">
    <div class="portfolio-header">
      <div>
        <div class="eyebrow reveal">
          <span class="eyebrow-bar" aria-hidden="true"></span>
          Portfolio
        </div>
        <h2 class="portfolio-h2 reveal" id="portfolio-heading">
          Ausgewählte<br/>Arbeiten.
        </h2>
      </div>
    </div>

    <div class="portfolio-list">
      {projects.map((p, i) => (
        <a href="/portfolio" class="portfolio-item reveal" style={`--item-accent:${p.accent};`} aria-label={`Projekt: ${p.title}`}>
          <span class="pf-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <div class="pf-meta">
              <span class="pf-cat">{p.category}</span>
              <span class="pf-year">{p.year}</span>
            </div>
            <div class="pf-title">{p.title}</div>
            <div class="pf-desc">{p.desc}</div>
            <div class="pf-tags">{p.tags.map(t => <span class="pf-tag">{t}</span>)}</div>
          </div>
          <div class="pf-arrow" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 11L11 3M11 3H6M11 3V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="portfolio-cta-row">
      <a href="/portfolio" class="btn-outline reveal">
        Alle Projekte ansehen
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>
