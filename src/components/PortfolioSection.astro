---
const projects = [
  {
    gradient: 'linear-gradient(135deg, rgba(127,119,221,0.28) 0%, rgba(127,119,221,0.04) 100%)',
    accentColor: '#AFA9EC',
    tag: 'Webdesign · Branding',
    title: 'Café Rösterei Köln',
    subtitle: 'Website + Corporate Identity',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(45,212,191,0.22) 0%, rgba(45,212,191,0.03) 100%)',
    accentColor: '#2DD4BF',
    tag: 'Webdesign · IT-Setup',
    title: 'Elektro Müller GmbH',
    subtitle: 'Website, Logo & lokale IT-Einrichtung',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(255,140,107,0.22) 0%, rgba(255,140,107,0.03) 100%)',
    accentColor: '#FF8C6B',
    tag: 'Branding',
    title: 'Fitnessstudio NordKöln',
    subtitle: 'Logo, Visitenkarten & Social Media Kit',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(127,119,221,0.14) 0%, rgba(13,13,24,0) 100%)',
    accentColor: '#AFA9EC',
    tag: 'IT-Services',
    title: 'Steuerberatung Hofmann',
    subtitle: 'Cloud-Migration & IT-Support Retainer',
  },
] as const;
---

<style>
  .pf-card {
    background: #13131f;
    border: 1px solid rgba(127,119,221,0.1);
    border-radius: 20px;
    overflow: hidden;
    transition:
      border-color 220ms var(--ease-out),
      transform    220ms var(--ease-out),
      box-shadow   220ms var(--ease-out);
  }

  @media (hover: hover) and (pointer: fine) {
    .pf-card:hover {
      border-color: rgba(127,119,221,0.28);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.35);
    }
  }

  .pf-preview {
    height: 180px;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
  }
  .pf-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(240,239,255,0.06) 1px, transparent 1px);
    background-size: 22px 22px;
  }
  .pf-tag {
    position: relative;
    font-size: 11px; letter-spacing: 0.07em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 100px;
    background: rgba(10,10,15,0.55); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .pf-body { padding: 1.5rem; }
  .pf-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #F0EFFF;
    margin: 0 0 0.375rem;
  }
  .pf-subtitle { font-size: 0.875rem; color: rgba(240,239,255,0.4); }

  .pf-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 640px) {
    .pf-grid { grid-template-columns: 1fr; }
  }
</style>

<section style="background:#0a0a0f; padding:7rem 0;">
  <div style="max-width:72rem; margin:0 auto; padding:0 2rem;">

    <!-- Header -->
    <div style="max-width:640px; margin-bottom:4rem;">
      <div style="width:36px; height:2px; background:#7F77DD; margin-bottom:1.5rem;"></div>
      <p style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(240,239,255,0.3); margin-bottom:1rem;">
        Ausgewählte Projekte
      </p>
      <h2 style="font-size:clamp(2rem,3vw,2.75rem); font-weight:700; color:#F0EFFF; line-height:1.1; margin:0 0 1.25rem;">
        Meine Arbeiten.
      </h2>
      <p style="font-size:1rem; color:rgba(240,239,255,0.5); line-height:1.75;">
        Jedes Projekt ist ein Vertrauensbeweis – hier siehst du, womit ich anderen Unternehmen geholfen habe.
      </p>
    </div>

    <!-- Cards — stagger-reveal -->
    <div class="pf-grid">
      {projects.map((p) => (
        <div class="pf-card stagger-reveal">
          <div class="pf-preview" style={`background:${p.gradient};`}>
            <div class="pf-dots" aria-hidden="true"></div>
            <span class="pf-tag" style={`color:${p.accentColor};`}>{p.tag}</span>
          </div>
          <div class="pf-body">
            <h3 class="pf-title">{p.title}</h3>
            <p class="pf-subtitle">{p.subtitle}</p>
          </div>
        </div>
      ))}
    </div>

    <div style="margin-top:3rem; text-align:center;">
      <a href="/portfolio" class="press-btn" style="
        display:inline-flex; align-items:center; gap:6px;
        color:#7F77DD; font-size:14px; text-decoration:none;
      ">
        Alle Projekte ansehen <span aria-hidden="true">→</span>
      </a>
    </div>

  </div>
</section>
