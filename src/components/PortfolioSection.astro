---
const projects = [
  {
    name: 'Café Rösterei Köln',
    cat: 'Webdesign',
    body: 'Moderner Online-Auftritt für eine Kölner Spezialitätenrösterei mit Online-Shop und Story-Seiten.',
    tag: 'Fertiggestellt',
    accent: '#7F77DD',
  },
  {
    name: 'Meisterbetrieb Schmitz',
    cat: 'IT-Setup & Branding',
    body: 'Neues Logo, Briefpapier und komplettes Cloud-Setup inkl. E-Mail-Migration für Sanitärbetrieb.',
    tag: 'Fertiggestellt',
    accent: '#2DD4BF',
  },
  {
    name: 'Kosmetikstudio Belle',
    cat: 'Webdesign',
    body: 'Booking-fähige Website mit Leistungsübersicht und Online-Terminbuchung via Calendly-Integration.',
    tag: 'In Bearbeitung',
    accent: '#FF8C6B',
  },
];
---

<style>
  .portfolio {
    background: var(--surface-1);
    padding: 6rem 5%;
    position: relative;
  }
  .portfolio::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 70% 0%, rgba(127,119,221,0.05) 0%, transparent 55%);
    pointer-events: none;
  }
  .portfolio-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    flex-wrap: wrap; gap: 1.5rem;
    margin-bottom: 3rem;
    position: relative; z-index: 1;
  }
  .portfolio-headline {
    font-size: clamp(1.875rem, 3vw, 2.625rem);
    font-weight: 700; letter-spacing: -0.025em; color: var(--text);
    max-width: 22ch; line-height: 1.2; margin: 0 0 1rem;
  }
  .portfolio-sub { font-size: 1rem; color: var(--text-muted); line-height: 1.7; }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    position: relative; z-index: 1;
  }

  .proj-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color 240ms var(--ease-out), transform 240ms var(--ease-out),
                box-shadow 240ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .proj-card:hover {
      transform: translateY(-3px);
      border-color: var(--proj-accent);
      box-shadow: 0 16px 40px rgba(0,0,0,0.3);
    }
  }

  .proj-visual {
    height: 160px;
    background: var(--surface-3);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .proj-visual-inner {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--proj-accent) 0%, transparent 65%);
    opacity: 0.07;
  }
  .proj-visual-icon {
    width: 56px; height: 56px; border-radius: var(--r-lg);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.07);
    display: flex; align-items: center; justify-content: center;
    color: var(--proj-accent);
    position: relative; z-index: 1;
  }

  .proj-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.875rem; flex: 1; }
  .proj-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .proj-cat {
    font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--proj-accent); font-family: 'Poppins', sans-serif; font-weight: 500;
  }
  .proj-tag {
    font-size: 11px; padding: 2px 8px; border-radius: var(--r-full);
    border: 1px solid var(--border); color: var(--text-dim);
    font-family: 'Poppins', sans-serif;
  }
  .proj-name {
    font-size: 1.0625rem; font-weight: 600; color: var(--text);
    font-family: 'Poppins', sans-serif; line-height: 1.3; margin: 0;
  }
  .proj-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.7; flex: 1; margin: 0; }

  .portfolio-cta { margin-top: 3rem; text-align: center; position: relative; z-index: 1; }

  @media (max-width: 599px) { .portfolio-grid { grid-template-columns: 1fr; } }
  @media (min-width: 600px) and (max-width: 900px) { .portfolio-grid { grid-template-columns: 1fr 1fr; } }
</style>

<section class="portfolio" aria-labelledby="portfolio-heading">
  <div class="section-inner">
    <div class="portfolio-head">
      <div>
        <div class="eyebrow">
          <div class="eyebrow-line"></div>
          <span class="eyebrow-text">Portfolio</span>
        </div>
        <h2 class="portfolio-headline" id="portfolio-heading">
          Projekte, die etwas bewegen.
        </h2>
        <p class="portfolio-sub">Echte Kunden. Echte Ergebnisse.</p>
      </div>
      <a href="/portfolio" class="btn-outline" aria-label="Alle Projekte ansehen">
        Alle ansehen
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7H11.5M8 3.5L11.5 7L8 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <div class="portfolio-grid">
      {projects.map((p) => (
        <article class="proj-card stagger-reveal" style={`--proj-accent:${p.accent};`}>
          <div class="proj-visual">
            <div class="proj-visual-inner" aria-hidden="true"></div>
            <div class="proj-visual-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8M12 17v4"/>
              </svg>
            </div>
          </div>
          <div class="proj-body">
            <div class="proj-meta">
              <span class="proj-cat">{p.cat}</span>
              <span class="proj-tag">{p.tag}</span>
            </div>
            <p class="proj-name">{p.name}</p>
            <p class="proj-desc">{p.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
