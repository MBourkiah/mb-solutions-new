---
const steps = [
  {
    num: '01',
    title: 'Kostenloses Erstgespräch',
    desc: 'Wir besprechen dein Projekt, deine Ziele und dein Budget — kein Verkaufsdruck, keine Verpflichtung. Einfach ein offenes Gespräch.',
    benefits: [
      'Telefonisch oder per Video-Call',
      'Kostenfrei, 30–45 Minuten',
      'Direktes Feedback zu deinen Ideen',
    ],
    icon: 'chat',
  },
  {
    num: '02',
    title: 'Konzept & Umsetzung',
    desc: 'Du erhältst ein klares Festpreisangebot. Nach deiner Freigabe starte ich — mit regelmäßigem Feedback und kurzen Abstimmungswegen.',
    benefits: [
      'Transparenter Festpreis, keine Stundensätze',
      'Fertigstellung in 2–6 Wochen',
      'Jederzeit Einblick in den aktuellen Stand',
    ],
    icon: 'code',
  },
  {
    num: '03',
    title: 'Live & dauerhafter Support',
    desc: 'Dein Auftritt geht online. Ich begleite dich auch danach — bei Updates, Erweiterungen und allen technischen Fragen bin ich direkt erreichbar.',
    benefits: [
      'Launch inkl. technischem Setup',
      'Direkter Kontakt auch nach Go-Live',
      'Kein Ticketsystem, kein Supportcenter',
    ],
    icon: 'check',
  },
];
---

<style>
  .process { background: var(--bg); padding: 6rem 5% 7rem; }
  .process-inner { max-width: 80rem; margin: 0 auto; }

  .process-header {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; margin-bottom: 3rem; gap: 0.875rem;
  }
  .process-h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800; letter-spacing: -0.04em;
    color: var(--text); line-height: 1.02; max-width: 20ch;
  }
  .process-sub {
    font-size: 1.0625rem; color: var(--text-2);
    line-height: 1.7; max-width: 46ch;
  }

  /* ── Connector strip (desktop only) ─────── */
  .process-connector {
    display: grid; grid-template-columns: repeat(3, 1fr);
    margin-bottom: -16px; position: relative; z-index: 2;
  }
  /* Line draws itself when connector enters viewport */
  .process-connector::before {
    content: '';
    position: absolute;
    top: 50%; transform: translateY(-50%) scaleX(0);
    transform-origin: left center;
    left: calc(16.667% + 24px);
    right: calc(16.667% + 24px);
    height: 1px;
    background: linear-gradient(90deg,
      rgba(127,119,221,0.8) 0%,
      rgba(127,119,221,0.35) 50%,
      rgba(127,119,221,0.8) 100%);
    z-index: 0;
    transition: transform 720ms var(--ease-out) 300ms;
  }
  .process-connector.visible::before {
    transform: translateY(-50%) scaleX(1);
  }
  .step-badge {
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--accent); color: white;
    font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    justify-self: center; position: relative; z-index: 1;
    box-shadow: 0 0 0 5px var(--bg), 0 0 0 6.5px rgba(127,119,221,0.30);
    letter-spacing: -0.03em;
    transition: transform 260ms var(--ease-out), box-shadow 260ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .step-badge:hover {
      transform: scale(1.1);
      box-shadow: 0 0 0 5px var(--bg), 0 0 0 7px rgba(127,119,221,0.5),
                  0 8px 24px rgba(127,119,221,0.3);
    }
  }

  /* ── Step cards grid ─────────────────────── */
  .process-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .process-step {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-xl); padding: 2.5rem 2rem;
    display: flex; flex-direction: column; gap: 0;
    box-shadow: var(--shadow-sm);
    transition: transform 260ms var(--ease-out), box-shadow 260ms var(--ease-out),
                border-color 260ms var(--ease-out);
    padding-top: 2.75rem;
  }
  @media (hover: hover) and (pointer: fine) {
    .process-step:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
      border-color: var(--border-a);
    }
    .process-step:hover .step-icon { transform: scale(1.1) rotate(-6deg); }
  }

  /* Mobile step number (shown when connector is hidden) */
  .step-num-mobile {
    font-family: 'Outfit', sans-serif; font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent);
    margin-bottom: 1.5rem; display: none;
  }

  .step-icon {
    width: 50px; height: 50px; border-radius: var(--r-md);
    background: var(--accent-light);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent); margin-bottom: 1.375rem;
    transition: transform 280ms var(--ease-out);
    will-change: transform;
  }
  .step-title {
    font-family: 'Outfit', sans-serif; font-size: 1.125rem; font-weight: 700;
    color: var(--text); letter-spacing: -0.025em; line-height: 1.25;
    margin-bottom: 0.75rem;
  }
  .step-desc {
    font-size: 0.9375rem; color: var(--text-2); line-height: 1.7;
    margin-bottom: 1.5rem; flex: 1;
  }
  .step-benefits {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 9px;
    padding-top: 1.375rem; border-top: 1px solid var(--border);
  }
  .step-benefits li {
    display: flex; align-items: flex-start; gap: 9px;
    font-size: 0.875rem; color: var(--text-2); line-height: 1.5;
  }
  .step-check {
    width: 17px; height: 17px; border-radius: 50%;
    background: #F0FDF4; border: 1px solid #BBF7D0;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 1px;
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 900px) {
    .process-grid { grid-template-columns: 1fr; gap: 12px; }
    .process-connector { display: none; }
    .step-num-mobile { display: block; }
    .process-step { padding-top: 2rem; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .process-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 599px) {
    .process { padding: 4rem 5% 4.5rem; }
    .process-step { padding: 1.875rem 1.5rem; }
  }
</style>

<section class="process" aria-labelledby="process-heading">
  <div class="process-inner">
    <div class="process-header">
      <div class="eyebrow reveal" style="justify-content:center;">
        <span class="eyebrow-bar" aria-hidden="true"></span>
        Ablauf
      </div>
      <h2 class="process-h2 reveal" id="process-heading">
        Vom Gespräch zum<br/>fertigen Auftritt.
      </h2>
      <p class="process-sub reveal">
        Drei klare Schritte — transparent, direkt und ohne Überraschungen.
      </p>
    </div>

    <div class="process-connector reveal" aria-hidden="true">
      {steps.map(s => (
        <div class="step-badge">{s.num}</div>
      ))}
    </div>

    <div class="process-grid">
      {steps.map(s => (
        <div class="process-step reveal-scale">
          <span class="step-num-mobile" aria-hidden="true">{s.num}</span>

          <div class="step-icon" aria-hidden="true">
            {s.icon === 'chat' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            )}
            {s.icon === 'code' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
              </svg>
            )}
            {s.icon === 'check' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            )}
          </div>

          <h3 class="step-title">{s.title}</h3>
          <p class="step-desc">{s.desc}</p>

          <ul class="step-benefits">
            {s.benefits.map(b => (
              <li>
                <span class="step-check" aria-hidden="true">
                  <svg width="9" height="9" viewBox="0 0 10 10" fill="none">
                    <path d="M2 5.5L4 7.5L8 3" stroke="#16A34A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
                {b}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
