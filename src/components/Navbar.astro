---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const links = [
  { href: '/leistungen', label: 'Leistungen' },
  { href: '/portfolio',  label: 'Portfolio' },
  { href: '/ueber-mich', label: 'Über mich' },
  { href: '/kontakt',    label: 'Kontakt' },
];
---

<style>
  .nav-wrap {
    position: sticky; top: 16px; z-index: 100;
    display: flex; justify-content: center;
    padding: 0 1.5rem;
    pointer-events: none;
  }
  .nav-bar {
    pointer-events: all;
    display: flex; align-items: center; justify-content: space-between;
    width: 100%; max-width: 68rem;
    background: rgba(245,243,238,0.88);
    backdrop-filter: blur(20px) saturate(1.8);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    border: 1px solid var(--border-2);
    border-radius: var(--r-xl);
    padding: 10px 16px 10px 16px;
    box-shadow: var(--shadow-md);
    transition: background 240ms var(--ease-out), box-shadow 240ms var(--ease-out);
  }
  .nav-bar.scrolled {
    background: rgba(245,243,238,0.96);
    box-shadow: var(--shadow-lg);
  }

  /* Logo */
  .logo {
    display: flex; align-items: center;
    text-decoration: none; flex-shrink: 0;
  }
  .logo-img {
    height: 48px; width: auto;
    display: block;
  }

  /* Nav links */
  .nav-links { display: flex; align-items: center; gap: 4px; }
  .nav-link {
    font-size: 13.5px; font-weight: 450; color: var(--text-2);
    text-decoration: none; padding: 7px 13px; border-radius: 8px;
    transition: color 140ms var(--ease-out), background 140ms var(--ease-out);
  }
  .nav-link.active {
    color: var(--text); background: var(--bg-alt);
    font-weight: 500;
  }
  @media (hover: hover) and (pointer: fine) {
    .nav-link:not(.active):hover {
      color: var(--text); background: var(--bg-alt);
    }
  }

  /* CTA */
  .nav-cta {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--accent); color: white;
    padding: 8px 16px; border-radius: 8px;
    font-size: 13px; font-weight: 600; text-decoration: none;
    font-family: 'Outfit', sans-serif; letter-spacing: -0.01em;
    transition: background 150ms var(--ease-out), transform 150ms var(--ease-out);
    flex-shrink: 0;
  }
  .nav-cta:active { transform: scale(0.97); }
  @media (hover: hover) and (pointer: fine) {
    .nav-cta:hover { background: var(--accent-dark); }
  }

  /* Hamburger */
  .menu-btn {
    display: none; flex-direction: column; justify-content: center;
    align-items: center; gap: 5px; width: 36px; height: 36px;
    background: transparent; border: none; padding: 0;
  }
  .menu-btn span {
    display: block; height: 1.5px; background: var(--text);
    border-radius: 1px; transition: width 200ms var(--ease-out);
  }

  /* Mobile overlay */
  .mobile-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: var(--bg);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transform: translateY(10px);
    transition: opacity 240ms var(--ease-out), transform 240ms var(--ease-out);
  }
  .mobile-overlay.open {
    opacity: 1; pointer-events: all;
    transform: translateY(0);
  }
  .mobile-close {
    position: absolute; top: 20px; right: 24px;
    width: 40px; height: 40px; background: none; border: none;
    display: flex; align-items: center; justify-content: center;
    color: var(--text-3);
  }
  .mobile-link {
    font-family: 'Outfit', sans-serif;
    font-size: 2.5rem; font-weight: 700; letter-spacing: -0.04em;
    color: var(--text); text-decoration: none; padding: 0.6rem 0;
    opacity: 0; transform: translateY(10px);
    transition: color 140ms var(--ease-out),
                opacity 260ms var(--ease-out),
                transform 260ms var(--ease-out);
  }
  .mobile-link.active { color: var(--accent); }
  .mobile-overlay.open .mobile-link { opacity: 1; transform: translateY(0); }
  .mobile-overlay.open .mobile-link:nth-child(1) { transition-delay: 60ms; }
  .mobile-overlay.open .mobile-link:nth-child(2) { transition-delay: 110ms; }
  .mobile-overlay.open .mobile-link:nth-child(3) { transition-delay: 160ms; }
  .mobile-overlay.open .mobile-link:nth-child(4) { transition-delay: 210ms; }
  @media (hover: hover) and (pointer: fine) {
    .mobile-link:hover { color: var(--accent); }
  }
  .mobile-cta { margin-top: 2rem; }

  @media (max-width: 768px) {
    .nav-links, .nav-cta { display: none; }
    .menu-btn { display: flex; }
  }
</style>

<div class="nav-wrap">
  <header id="nav-bar" class="nav-bar">
    <a href="/" class="logo">
      <img
        src="/logos/mb-solutions-horizontal.svg"
        alt="MB-Solutions Logo"
        class="logo-img"
        width="180"
        height="30"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="nav-links" aria-label="Hauptnavigation">
      {links.map(l => (
        <a
          href={l.href}
          class={`nav-link ${isActive(l.href) ? 'active' : ''}`}
          aria-current={isActive(l.href) ? 'page' : undefined}
        >{l.label}</a>
      ))}
    </nav>

    <div style="display:flex;align-items:center;gap:8px;">
      <a href="/kontakt" class="nav-cta hidden md:inline-flex">
        Anfragen
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <button id="menu-btn" class="menu-btn md:hidden" aria-label="Menü öffnen" aria-expanded="false">
        <span style="width:22px;"></span>
        <span style="width:15px;"></span>
      </button>
    </div>
  </header>
</div>

<div id="mobile-overlay" class="mobile-overlay" aria-hidden="true" role="dialog" aria-label="Navigation">
  <button id="mobile-close" class="mobile-close" aria-label="Menü schließen">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
      <path d="M15 5L5 15M5 5l10 10"/>
    </svg>
  </button>
  <nav style="display:flex;flex-direction:column;align-items:center;" aria-label="Mobile Navigation">
    {links.map(l => (
      <a href={l.href} class={`mobile-link ${isActive(l.href) ? 'active' : ''}`}>{l.label}</a>
    ))}
  </nav>
  <a href="/kontakt" class="btn-primary mobile-cta">Anfragen →</a>
</div>

<script>
  const bar     = document.getElementById('nav-bar');
  const btn     = document.getElementById('menu-btn');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn= document.getElementById('mobile-close');

  window.addEventListener('scroll', () => {
    bar?.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  btn?.addEventListener('click', () => {
    overlay?.classList.add('open');
    overlay?.setAttribute('aria-hidden', 'false');
    btn.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  });
  const close = () => {
    overlay?.classList.remove('open');
    overlay?.setAttribute('aria-hidden', 'true');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };
  closeBtn?.addEventListener('click', close);
  overlay?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>
