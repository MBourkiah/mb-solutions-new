---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const navLinks = [
  { href: '/leistungen', label: 'Leistungen' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/ueber-mich', label: 'Über mich' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<style>
  .nav-link {
    font-size: 14px;
    text-decoration: none;
    transition: color 150ms var(--ease-out);
    color: rgba(240,239,255,0.5);
  }
  .nav-link.active { color: #F0EFFF; font-weight: 500; }
  @media (hover: hover) and (pointer: fine) {
    .nav-link:hover { color: #F0EFFF; }
  }

  .overlay-link {
    font-size: 1.75rem;
    text-decoration: none;
    padding: 0.75rem 0;
    transition: color 150ms var(--ease-out);
    color: rgba(240,239,255,0.4);
  }
  .overlay-link.active { color: #F0EFFF; font-weight: 600; }
  @media (hover: hover) and (pointer: fine) {
    .overlay-link:hover { color: #F0EFFF; }
  }

  .nav-cta {
    background: #7F77DD;
    color: white;
    transition: background 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .nav-cta:active { transform: scale(0.97); }
  @media (hover: hover) and (pointer: fine) {
    .nav-cta:hover { background: #6B63C9; }
  }
</style>

<header
  id="navbar"
  class="sticky top-0 z-50 h-16"
  style="background: #0a0a0f; transition: background 200ms, border-bottom 200ms;"
>
  <div class="flex items-center justify-between h-full px-6 md:px-12 lg:px-20">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0" style="text-decoration:none;">
      <span
        class="flex items-center justify-center w-7 h-7 rounded-lg bg-primary text-white font-bold leading-none"
        style="font-size:10px; letter-spacing:-0.02em;"
        aria-hidden="true"
      >MB</span>
      <span style="font-weight:600; font-size:15px; color:#F0EFFF;">MB-Solutions</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Hauptnavigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <a
        href="/kontakt"
        id="nav-cta"
        class="nav-cta hidden md:inline-flex items-center px-5 py-2 rounded-full text-sm font-medium"
      >
        Projekt anfragen
      </a>

      <!-- Mobile Hamburger -->
      <button
        id="menu-btn"
        class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.25"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-overlay"
      >
        <span style="display:block;width:20px;height:1px;background:rgba(240,239,255,0.7);"></span>
        <span style="display:block;width:20px;height:1px;background:rgba(240,239,255,0.7);"></span>
        <span style="display:block;width:20px;height:1px;background:rgba(240,239,255,0.7);"></span>
      </button>
    </div>

  </div>
</header>

<!-- Mobile Fullscreen Overlay -->
<div
  id="mobile-overlay"
  class="fixed inset-0 z-100 flex flex-col items-center justify-center opacity-0 pointer-events-none"
  style="background:#0a0a0f; transition:opacity 150ms ease;"
  aria-hidden="true"
>
  <button
    id="close-btn"
    class="absolute top-5 right-6 w-10 h-10 flex items-center justify-center"
    style="color:rgba(240,239,255,0.35);"
    aria-label="Menü schließen"
  >
    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12" />
    </svg>
  </button>

  <nav class="flex flex-col items-center" aria-label="Mobile Navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class={`overlay-link ${isActive(link.href) ? 'active' : ''}`}
      >
        {link.label}
      </a>
    ))}
    <a
      href="/kontakt"
      class="mt-8 px-8 py-3 rounded-full text-white text-base font-medium"
      style="background:#7F77DD;"
    >
      Projekt anfragen
    </a>
  </nav>
</div>

<script>
  const header = document.getElementById('navbar') as HTMLElement | null;

  function updateScroll() {
    if (!header) return;
    if (window.scrollY > 20) {
      header.style.borderBottom = '1px solid rgba(127,119,221,0.12)';
      header.style.background   = 'rgba(10,10,15,0.92)';
      header.style.backdropFilter = 'blur(16px)';
      (header.style as CSSStyleDeclaration & { webkitBackdropFilter: string }).webkitBackdropFilter = 'blur(16px)';
    } else {
      header.style.borderBottom = '';
      header.style.background   = '#0a0a0f';
      header.style.backdropFilter = '';
      (header.style as CSSStyleDeclaration & { webkitBackdropFilter: string }).webkitBackdropFilter = '';
    }
  }
  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();

  const menuBtn = document.getElementById('menu-btn');
  const closeBtn = document.getElementById('close-btn');
  const overlay  = document.getElementById('mobile-overlay');

  function openMenu() {
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    overlay?.classList.add('opacity-100');
    overlay?.setAttribute('aria-hidden', 'false');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    overlay?.classList.remove('opacity-100');
    overlay?.setAttribute('aria-hidden', 'true');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  menuBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.querySelectorAll('a').forEach((l) => l.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>
