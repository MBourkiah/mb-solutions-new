---
const year = new Date().getFullYear();
---

<style>
  .footer { background: #070710; border-top: 1px solid rgba(127,119,221,0.12); }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .footer-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240,239,255,0.22);
    margin-bottom: 1.25rem;
  }
  .footer-link {
    display: block;
    font-size: 14px;
    color: rgba(240,239,255,0.45);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: color 150ms;
  }
  .footer-link:hover { color: #F0EFFF; }

  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<footer class="footer">
  <div style="max-width:72rem; margin:0 auto; padding:4rem 2rem 2rem;">

    <div class="footer-grid">

      <!-- Logo + Tagline -->
      <div>
        <a href="/" style="display:inline-flex; align-items:center; gap:10px; text-decoration:none; margin-bottom:1rem;">
          <span style="display:flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:8px; background:#7F77DD; font-size:10px; font-weight:700; color:white; letter-spacing:-0.02em;">MB</span>
          <span style="font-weight:600; font-size:15px; color:#F0EFFF;">MB-Solutions</span>
        </a>
        <p style="font-size:13px; color:rgba(240,239,255,0.32); line-height:1.7; max-width:180px;">
          Webdesign, IT-Services & Branding für KMU in Köln.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="footer-label">Seiten</p>
        <a href="/leistungen" class="footer-link">Leistungen</a>
        <a href="/portfolio" class="footer-link">Portfolio</a>
        <a href="/ueber-mich" class="footer-link">Über mich</a>
        <a href="/kontakt" class="footer-link">Kontakt</a>
      </div>

      <!-- Contact -->
      <div>
        <p class="footer-label">Kontakt</p>
        <a href="mailto:mbourkiah@k-solutions.biz" class="footer-link">mbourkiah@k-solutions.biz</a>
        <p style="font-size:14px; color:rgba(240,239,255,0.4);">Köln, Deutschland</p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div style="padding-top:1.75rem; border-top:1px solid rgba(127,119,221,0.07); display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem;">
      <p style="font-size:12px; color:rgba(240,239,255,0.18);">&copy; {year} MB-Solutions, Köln</p>
      <div style="display:flex; gap:1.5rem;">
        <a href="/impressum" style="font-size:12px; color:rgba(240,239,255,0.22); text-decoration:none; transition:color 150ms;">Impressum</a>
        <a href="/datenschutz" style="font-size:12px; color:rgba(240,239,255,0.22); text-decoration:none; transition:color 150ms;">Datenschutz</a>
      </div>
    </div>

  </div>
</footer>
