---
// No props – static form, submit handled by client-side JS
---

<style>
  .cf-label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: rgba(240,239,255,0.65);
    margin-bottom: 6px;
  }
  .cf-input, .cf-select, .cf-textarea {
    width: 100%;
    background: #0d0d18;
    border: 1px solid rgba(127,119,221,0.18);
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 14px;
    color: #F0EFFF;
    font-family: inherit;
    transition: border-color 150ms var(--ease-out), box-shadow 150ms var(--ease-out);
    outline: none;
    box-sizing: border-box;
  }
  .cf-input::placeholder, .cf-textarea::placeholder { color: rgba(240,239,255,0.22); }
  .cf-input:focus, .cf-select:focus, .cf-textarea:focus {
    border-color: rgba(127,119,221,0.5);
    box-shadow: 0 0 0 3px rgba(127,119,221,0.1);
  }
  .cf-select { appearance: none; cursor: pointer; }
  .cf-select option { background: #13131f; color: #F0EFFF; }
  .cf-textarea { resize: none; }
  .cf-btn {
    width: 100%;
    padding: 14px;
    border-radius: 12px;
    background: #7F77DD;
    color: white;
    font-size: 14px;
    font-weight: 600;
    font-family: inherit;
    border: none;
    cursor: pointer;
    transition: background 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .cf-btn:active:not(:disabled) { transform: scale(0.97); }
  .cf-btn:disabled { opacity: 0.55; cursor: not-allowed; }
  @media (hover: hover) and (pointer: fine) {
    .cf-btn:hover:not(:disabled) { background: #6B63C9; }
  }
</style>

<div id="form-wrapper">
  <form id="contact-form" style="display:flex; flex-direction:column; gap:1.25rem;" novalidate>

    <div>
      <label for="name" class="cf-label">Name <span style="color:#7F77DD" aria-hidden="true">*</span></label>
      <input type="text" id="name" name="name" required autocomplete="name"
        placeholder="Max Mustermann" class="cf-input" />
    </div>

    <div>
      <label for="email" class="cf-label">E-Mail <span style="color:#7F77DD" aria-hidden="true">*</span></label>
      <input type="email" id="email" name="email" required autocomplete="email"
        placeholder="max@beispiel.de" class="cf-input" />
    </div>

    <div>
      <label for="service" class="cf-label">Ich interessiere mich für <span style="color:#7F77DD" aria-hidden="true">*</span></label>
      <div style="position:relative;">
        <select id="service" name="service" required class="cf-select" style="padding-right:2.5rem;">
          <option value="" disabled selected>Service wählen…</option>
          <option value="Webdesign">Webdesign</option>
          <option value="IT-Services">IT-Services</option>
          <option value="Branding & Marketing">Branding &amp; Marketing</option>
          <option value="Komplettpaket">Komplettpaket</option>
          <option value="Sonstiges">Sonstiges</option>
        </select>
        <div style="position:absolute; right:12px; top:50%; transform:translateY(-50%); pointer-events:none; color:rgba(240,239,255,0.35);" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 6l4 4 4-4" />
          </svg>
        </div>
      </div>
    </div>

    <div>
      <label for="message" class="cf-label">Nachricht <span style="color:#7F77DD" aria-hidden="true">*</span></label>
      <textarea id="message" name="message" required rows="5"
        placeholder="Erzähl mir kurz von deinem Projekt oder deiner Situation…"
        class="cf-textarea"></textarea>
    </div>

    <div>
      <button type="submit" id="submit-btn" class="cf-btn">Anfrage senden</button>
      <p id="error-message" class="hidden" style="margin-top:0.75rem; font-size:13px; color:#FF8C6B; text-align:center; line-height:1.6;">
        Etwas ist schiefgelaufen. Schreib mir direkt an
        <a href="mailto:mbourkiah@mb-solutions.biz" style="text-decoration:underline; font-weight:500; white-space:nowrap;">
          mbourkiah@mb-solutions.biz
        </a>
      </p>
    </div>

  </form>
</div>

<!-- Success State -->
<div id="success-message" class="hidden" style="text-align:center; padding:3rem 1rem;">
  <div style="width:56px; height:56px; border-radius:50%; background:rgba(45,212,191,0.12); border:1px solid rgba(45,212,191,0.3); display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2DD4BF"
      stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20 6L9 17l-5-5" />
    </svg>
  </div>
  <h3 style="font-size:1.125rem; font-weight:600; color:#F0EFFF; margin:0 0 0.5rem;">Nachricht erhalten!</h3>
  <p style="font-size:14px; color:rgba(240,239,255,0.5); line-height:1.7;">
    Ich melde mich innerhalb von 48 Stunden bei dir.
  </p>
</div>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn  = document.getElementById('submit-btn')   as HTMLButtonElement | null;
  const errorMsg   = document.getElementById('error-message');
  const formWrapper= document.getElementById('form-wrapper');
  const successMsg = document.getElementById('success-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !form) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet…';
    errorMsg?.classList.add('hidden');

    const data = {
      name:    (form.elements.namedItem('name')    as HTMLInputElement).value.trim(),
      email:   (form.elements.namedItem('email')   as HTMLInputElement).value.trim(),
      service: (form.elements.namedItem('service') as HTMLSelectElement).value,
      message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
    };

    try {
      const res    = await fetch('/api/contact', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(data) });
      const result = await res.json();
      if (result.success) {
        formWrapper?.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        throw new Error(result.error ?? 'Unbekannter Fehler');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Anfrage senden';
    }
  });
</script>
