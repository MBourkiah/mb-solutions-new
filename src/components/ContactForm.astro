---
// No props – static form, submit handled by client-side JS
---

<style>
  .contact-form-wrap {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    padding: 2.5rem;
    max-width: 560px;
    width: 100%;
  }
  .form-title {
    font-size: 1.25rem; font-weight: 700; color: var(--text);
    font-family: 'Poppins', sans-serif; margin: 0 0 0.375rem;
  }
  .form-sub { font-size: 0.875rem; color: var(--text-muted); margin: 0 0 2rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 1.125rem; }
  .form-label {
    font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-dim); font-family: 'Poppins', sans-serif; font-weight: 500;
  }
  .form-input {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    color: var(--text);
    font-family: 'Inter', sans-serif; font-size: 0.9375rem;
    padding: 11px 14px;
    outline: none;
    transition: border-color 160ms var(--ease-out), box-shadow 160ms var(--ease-out);
    width: 100%;
  }
  .form-input::placeholder { color: var(--text-dim); }
  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(127,119,221,0.14);
  }
  textarea.form-input { resize: vertical; min-height: 130px; }

  .form-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .form-status {
    display: none; padding: 12px 16px; border-radius: var(--r-md);
    font-size: 0.875rem; margin-top: 1rem;
  }
  .form-status.success {
    display: block;
    background: rgba(45,212,191,0.08);
    border: 1px solid rgba(45,212,191,0.2);
    color: #2DD4BF;
  }
  .form-status.error {
    display: block;
    background: rgba(255,140,107,0.08);
    border: 1px solid rgba(255,140,107,0.2);
    color: #FF8C6B;
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 1.75rem 1.25rem; }
  }
</style>

<div class="contact-form-wrap">
  <p class="form-title">Nachricht schreiben</p>
  <p class="form-sub">Ich melde mich innerhalb von 48 Stunden zurück.</p>

  <form id="contact-form" novalidate>
    <div class="form-row">
      <div class="form-group">
        <label for="cf-name" class="form-label">Name</label>
        <input
          type="text" id="cf-name" name="name"
          class="form-input" placeholder="Max Mustermann"
          required autocomplete="name"
        />
      </div>
      <div class="form-group">
        <label for="cf-email" class="form-label">E-Mail</label>
        <input
          type="email" id="cf-email" name="email"
          class="form-input" placeholder="max@beispiel.de"
          required autocomplete="email"
        />
      </div>
    </div>

    <div class="form-group">
      <label for="cf-subject" class="form-label">Betreff</label>
      <input
        type="text" id="cf-subject" name="subject"
        class="form-input" placeholder="Neue Website / IT-Frage / ..."
      />
    </div>

    <div class="form-group">
      <label for="cf-message" class="form-label">Nachricht</label>
      <textarea
        id="cf-message" name="message"
        class="form-input" placeholder="Erzähl mir von deinem Projekt..."
        required
      ></textarea>
    </div>

    <button type="submit" class="btn-primary form-submit press-btn">
      Nachricht senden
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>

    <div id="form-status" class="form-status" role="status" aria-live="polite"></div>
  </form>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!statusEl) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const orig = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Wird gesendet…';

    await new Promise(r => setTimeout(r, 900));

    statusEl.textContent = 'Danke! Ich melde mich bald bei dir.';
    statusEl.className = 'form-status success';
    form.reset();
    btn.disabled = false;
    btn.textContent = orig;
  });
</script>
