---
const services = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
    label: 'Webdesign & Entwicklung',
    body: 'Schnelle, mobile-first Websites die Kunden überzeugen — von der Konzeption bis zum Launch.',
    accent: 'var(--accent)',
    glow: 'rgba(127,119,221,0.08)',
    items: ['Responsive Design', 'Performance-Optimierung', 'CMS-Integration', 'SEO-Grundlagen'],
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/></svg>`,
    label: 'IT-Services & Setup',
    body: 'Alles, damit dein Betrieb digital läuft: E-Mail, Cloud, Hardware und laufende Betreuung.',
    accent: '#2DD4BF',
    glow: 'rgba(45,212,191,0.07)',
    items: ['E-Mail & Domain', 'Cloud-Setup', 'Datensicherung', 'Remote-Support'],
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    label: 'Branding & Corporate Identity',
    body: 'Logo, Farben und Visitenkarten — ein stimmiges Erscheinungsbild, das in Erinnerung bleibt.',
    accent: '#FF8C6B',
    glow: 'rgba(255,140,107,0.07)',
    items: ['Logo-Design', 'Farbkonzept', 'Visitenkarten', 'Briefpapier'],
  },
];
---

<style>
  .services {
    background: var(--bg);
    padding: 6rem 5%;
  }
  .services-header { margin-bottom: 3.5rem; }
  .services-headline {
    font-size: clamp(1.875rem, 3vw, 2.625rem);
    font-weight: 700; letter-spacing: -0.025em; color: var(--text);
    max-width: 28ch; line-height: 1.2; margin: 0 0 1rem;
  }
  .services-sub {
    font-size: 1rem; color: var(--text-muted); max-width: 52ch; line-height: 1.75;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .svc-card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 2rem;
    display: flex; flex-direction: column; gap: 1.25rem;
    transition: border-color 240ms var(--ease-out), transform 240ms var(--ease-out),
                box-shadow 240ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .svc-card:hover {
      transform: translateY(-3px);
      border-color: var(--card-accent);
      box-shadow: 0 12px 36px rgba(0,0,0,0.28);
    }
  }
  .svc-icon-wrap {
    width: 46px; height: 46px; border-radius: var(--r-md);
    display: flex; align-items: center; justify-content: center;
    background: var(--card-glow);
    color: var(--card-accent);
    flex-shrink: 0;
  }
  .svc-label {
    font-size: 1.0625rem; font-weight: 600; color: var(--text);
    font-family: 'Poppins', sans-serif; line-height: 1.3; margin: 0;
  }
  .svc-body { font-size: 0.875rem; color: var(--text-muted); line-height: 1.75; flex: 1; margin: 0; }
  .svc-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 7px; }
  .svc-list li {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.8125rem; color: var(--text-dim);
  }
  .svc-list li svg { flex-shrink: 0; color: var(--card-accent); }

  @media (max-width: 599px) {
    .services-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 901px) {
    .services-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>

<section class="services" aria-labelledby="services-heading">
  <div class="section-inner">
    <header class="services-header">
      <div class="eyebrow">
        <div class="eyebrow-line"></div>
        <span class="eyebrow-text">Leistungen</span>
      </div>
      <h2 class="services-headline" id="services-heading">
        Alles aus einer Hand,<br/>direkt aus Köln.
      </h2>
      <p class="services-sub">
        Kein Projektmanager dazwischen — du sprichst direkt mit dem, der's baut.
      </p>
    </header>

    <div class="services-grid">
      {services.map((s) => (
        <article
          class="svc-card stagger-reveal"
          style={`--card-accent:${s.accent};--card-glow:${s.glow};`}
        >
          <div class="svc-icon-wrap" aria-hidden="true" set:html={s.icon}></div>
          <p class="svc-label">{s.label}</p>
          <p class="svc-body">{s.body}</p>
          <ul class="svc-list">
            {s.items.map(item => (
              <li>
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2.5 7.5L5.5 10.5L11.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
