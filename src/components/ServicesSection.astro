---
const services = [
  {
    tag: 'Webdesign',
    tagBg: 'rgba(127,119,221,0.12)',
    tagColor: '#AFA9EC',
    title: 'Websites, die verkaufen.',
    description: 'Moderne, schnelle Webseiten mit klarer Struktur. WordPress, Webflow oder Custom-Code – je nach Bedarf und Budget.',
    price: 'ab 499 €',
    href: '/leistungen',
  },
  {
    tag: 'IT-Services',
    tagBg: 'rgba(45,212,191,0.1)',
    tagColor: '#2DD4BF',
    title: 'IT ohne Chaos.',
    description: 'Einrichtung, Wartung, Cloud-Setup und Support. Ich übernehme das zuverlässig – du konzentrierst dich auf dein Business.',
    price: 'ab 45 €/Std.',
    href: '/leistungen',
  },
  {
    tag: 'Branding',
    tagBg: 'rgba(255,140,107,0.1)',
    tagColor: '#FF8C6B',
    title: 'Marken, die bleiben.',
    description: 'Logo, Visitenkarten, Corporate Design – dein professioneller Auftritt von Anfang an, der Vertrauen aufbaut und in Erinnerung bleibt.',
    price: 'ab 149 €',
    href: '/leistungen',
  },
] as const;
---

<style>
  .svc-section { background: #0d0d18; padding: 7rem 0; }

  .svc-card {
    background: #13131f;
    border: 1px solid rgba(127,119,221,0.12);
    border-radius: 20px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    /* transition only what's needed — no "all" */
    transition:
      border-color 220ms var(--ease-out),
      box-shadow   220ms var(--ease-out);
  }

  /* Hover: guarded for pointer devices only */
  @media (hover: hover) and (pointer: fine) {
    .svc-card:hover {
      border-color: rgba(127,119,221,0.32);
      box-shadow: 0 0 36px rgba(127,119,221,0.06);
    }
  }

  .svc-tag {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
    margin-bottom: 1.25rem;
  }
  .svc-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #F0EFFF;
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .svc-desc {
    font-size: 0.9375rem;
    color: rgba(240,239,255,0.5);
    line-height: 1.75;
    flex: 1;
  }
  .svc-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(127,119,221,0.1);
  }
  .svc-price {
    font-size: 1.125rem;
    font-weight: 600;
    color: #F0EFFF;
  }
  .svc-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: #7F77DD;
    text-decoration: none;
    transition: gap 150ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .svc-link:active { transform: scale(0.95); }

  @media (hover: hover) and (pointer: fine) {
    .svc-link:hover { gap: 9px; }
  }

  .svc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) {
    .svc-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="svc-section">
  <div style="max-width:72rem; margin:0 auto; padding:0 2rem;">

    <!-- Header -->
    <div style="max-width:640px; margin-bottom:4rem;">
      <div style="width:36px; height:2px; background:#7F77DD; margin-bottom:1.5rem;"></div>
      <p style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(240,239,255,0.3); margin-bottom:1rem;">
        Was ich mache
      </p>
      <h2 style="font-size:clamp(2rem,3vw,2.75rem); font-weight:700; color:#F0EFFF; line-height:1.1; margin:0 0 1.25rem;">
        Alles aus einer Hand.
      </h2>
      <p style="font-size:1rem; color:rgba(240,239,255,0.5); line-height:1.75;">
        Kein Agentur-Chaos, kein Koordinationsaufwand – ich bin dein einziger Ansprechpartner für deinen kompletten digitalen Auftritt.
      </p>
    </div>

    <!-- Cards — stagger-reveal activated by IntersectionObserver -->
    <div class="svc-grid">
      {services.map((s) => (
        <div class="svc-card stagger-reveal">
          <span class="svc-tag" style={`background:${s.tagBg}; color:${s.tagColor};`}>{s.tag}</span>
          <h3 class="svc-title">{s.title}</h3>
          <p class="svc-desc">{s.description}</p>
          <div class="svc-footer">
            <span class="svc-price">{s.price}</span>
            <a href={s.href} class="svc-link">Mehr erfahren <span aria-hidden="true">→</span></a>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
