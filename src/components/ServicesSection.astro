---
const services = [
  {
    title: 'Webdesign',
    description:
      'Moderne, schnelle Webseiten mit klarer Struktur. WordPress, Webflow oder Custom – je nach Bedarf und Budget.',
    price: 'ab 499 €',
    priceClass: 'text-primary',
    iconBg: 'bg-primary/10',
    iconColor: 'text-primary',
    icon: 'monitor',
  },
  {
    title: 'IT-Services',
    description:
      'Einrichtung, Wartung, Cloud-Setup & Support. Kein IT-Chaos mehr – ich übernehme das zuverlässig für dich.',
    price: 'ab 45 €/Std.',
    priceClass: 'text-emerald-700',
    iconBg: 'bg-emerald-50',
    iconColor: 'text-emerald-600',
    icon: 'server',
  },
  {
    title: 'Branding & Marketing',
    description:
      'Logo, Visitenkarten, Corporate Design – dein professioneller Auftritt von Anfang an, der in Erinnerung bleibt.',
    price: 'ab 149 €',
    priceClass: 'text-orange-700',
    iconBg: 'bg-orange-50',
    iconColor: 'text-orange-600',
    icon: 'brush',
  },
] as const;
---

<section class="bg-white py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center mb-16">
      <p class="text-primary font-medium tracking-wide uppercase text-sm mb-3">
        Leistungen
      </p>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
        Alles aus einer Hand.
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed">
        Kein Agentur-Chaos, kein Koordinationsaufwand – ich bin dein einziger
        Ansprechpartner für deinen kompletten digitalen Auftritt.
      </p>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group border border-gray-100 rounded-2xl p-8 hover:border-primary/30 hover:shadow-md transition-all duration-200 flex flex-col">

          <!-- Icon Box -->
          <div class={`w-11 h-11 rounded-xl flex items-center justify-center mb-6 shrink-0 ${service.iconBg}`}>
            <span class={`w-5 h-5 ${service.iconColor}`}>
              {service.icon === 'monitor' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="3" width="20" height="14" rx="2" />
                  <path d="M8 21h8M12 17v4" />
                </svg>
              )}
              {service.icon === 'server' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="8" rx="2" />
                  <rect x="2" y="14" width="20" height="8" rx="2" />
                  <circle cx="7" cy="6" r="1" fill="currentColor" stroke="none" />
                  <circle cx="7" cy="18" r="1" fill="currentColor" stroke="none" />
                </svg>
              )}
              {service.icon === 'brush' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
                  <path d="m15.5 5.5 3 3" />
                </svg>
              )}
            </span>
          </div>

          <!-- Title -->
          <h3 class="text-xl font-semibold text-gray-900 mb-3">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-500 leading-relaxed flex-1">
            {service.description}
          </p>

          <!-- Price -->
          <div class="mt-8 pt-6 border-t border-gray-100">
            <a
              href="/kontakt"
              class={`inline-flex items-center gap-1.5 font-medium text-sm group-hover:gap-2.5 transition-all duration-150 ${service.priceClass}`}
            >
              {service.price}
              <span aria-hidden="true">→</span>
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
