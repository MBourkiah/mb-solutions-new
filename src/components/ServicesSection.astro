---
const services = [
  {
    num: '001',
    title: 'Webdesign & Entwicklung',
    desc: 'Moderne, schnelle Websites und Web-Apps für KMU. Von der ersten Skizze bis zum Live-Deployment — inkl. SEO-Grundlagen und Mobiloptimierung.',
    tags: ['Astro', 'Next.js', 'Tailwind CSS', 'Vercel'],
    color: 'var(--accent)',
    bg: 'var(--accent-light)',
    icon: 'web',
  },
  {
    num: '002',
    title: 'IT-Services & Cloud-Setup',
    desc: 'Strukturiertes IT-Setup für deinen Betrieb: E-Mail-Systeme, Cloud-Backup, Geräteeinrichtung und laufende Betreuung ohne Agentur-Overhead.',
    tags: ['Google Workspace', 'Microsoft 365', 'Cloud-Backup', 'IT-Support'],
    color: '#16A34A',
    bg: '#F0FDF4',
    icon: 'it',
  },
  {
    num: '003',
    title: 'Branding & Corporate Identity',
    desc: 'Logo, Farben, Typografie und Corporate Identity — konsistentes Erscheinungsbild, das zu deinem Betrieb und deiner Zielgruppe passt.',
    tags: ['Logo-Design', 'CI/CD-Manual', 'Figma', 'Print-Vorlagen'],
    color: '#D97706',
    bg: '#FFFBEB',
    icon: 'brand',
  },
];
---

<style>
  .services {
    background: var(--bg-alt);
    padding: 6rem 5% 7rem;
  }
  .services-inner { max-width: 80rem; margin: 0 auto; }

  .services-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 3.5rem; gap: 2rem; flex-wrap: wrap;
  }
  .services-h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800; letter-spacing: -0.04em;
    color: var(--text); line-height: 1.0; max-width: 16ch;
  }
  .services-sub {
    font-size: 1rem; color: var(--text-2);
    line-height: 1.7; max-width: 38ch; text-align: right;
  }

  .services-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }

  .service-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-xl); padding: 2.5rem 2rem;
    display: flex; flex-direction: column;
    box-shadow: var(--shadow-sm);
    transition: box-shadow 240ms var(--ease-out), transform 240ms var(--ease-out),
                border-color 240ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .service-card:hover {
      box-shadow: var(--shadow-lg);
      transform: translateY(-4px);
      border-color: var(--border-2);
    }
    .service-card:hover .service-icon { transform: scale(1.07); }
  }

  .service-num {
    font-family: 'Outfit', sans-serif; font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 2.5rem;
  }
  .service-icon {
    width: 52px; height: 52px; border-radius: var(--r-md);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 1.5rem;
    transition: transform 280ms var(--ease-out);
    will-change: transform;
  }
  .service-title {
    font-size: 1.1875rem; font-weight: 700; letter-spacing: -0.025em;
    color: var(--text); line-height: 1.2; margin-bottom: 0.875rem;
  }
  .service-desc {
    font-size: 0.9375rem; color: var(--text-2); line-height: 1.7;
    margin-bottom: 2rem; flex: 1;
  }
  .service-cta {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; font-weight: 600; text-decoration: none;
    margin-bottom: 1.5rem; font-family: 'Outfit', sans-serif;
  }
  .service-cta svg {
    transition: transform 150ms var(--ease-out);
    flex-shrink: 0;
  }
  @media (hover: hover) and (pointer: fine) {
    .service-cta:hover svg { transform: translate(3px, -3px); }
  }

  .service-tags {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: auto; padding-top: 1.5rem; border-top: 1px solid var(--border);
  }
  .service-tag {
    font-size: 11px; font-weight: 500; color: var(--text-3);
    background: var(--bg); border: 1px solid var(--border);
    padding: 3px 9px; border-radius: var(--r-full);
  }

  .services-cta-row { display: flex; justify-content: center; margin-top: 3rem; }

  @media (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr; }
    .services-header { flex-direction: column; align-items: flex-start; }
    .services-sub { text-align: left; }
  }
  @media (min-width: 600px) and (max-width: 900px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<section class="services" aria-labelledby="services-heading">
  <div class="services-inner">

    <div class="services-header">
      <div>
        <div class="eyebrow reveal">
          <span class="eyebrow-bar" aria-hidden="true"></span>
          Leistungen
        </div>
        <h2 class="services-h2 reveal" id="services-heading">
          Was ich für<br/>dich tue.
        </h2>
      </div>
      <p class="services-sub reveal">
        Alle Leistungen aus einer Hand — ohne Schnittstellen,
        ohne Missverständnisse, direkt und transparent.
      </p>
    </div>

    <div class="services-grid">
      {services.map(s => (
        <div class="service-card reveal">
          <span class="service-num" style={`color:${s.color};`}>{s.num}</span>

          <div class="service-icon" style={`background:${s.bg};`} aria-hidden="true">
            {s.icon === 'web' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={s.color} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
              </svg>
            )}
            {s.icon === 'it' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={s.color} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
              </svg>
            )}
            {s.icon === 'brand' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={s.color} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/>
                <path d="M12 3v3M12 18v3M3 12h3M18 12h3"/>
              </svg>
            )}
          </div>

          <h3 class="service-title">{s.title}</h3>
          <p class="service-desc">{s.desc}</p>

          <a href="/leistungen" class="service-cta" style={`color:${s.color};`}>
            Mehr erfahren
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <div class="service-tags">
            {s.tags.map(t => <span class="service-tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>

    <div class="services-cta-row">
      <a href="/leistungen" class="btn-outline reveal">
        Alle Leistungen ansehen
        <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
          <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>
</section>
