---
// Hero — Trust & Authority pattern (ui-ux-pro-max: landing.csv)
---

<style>
  .hero {
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    padding: 7rem 5% 5rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -20%; left: -8%;
    width: 55%; height: 90%;
    background: radial-gradient(ellipse at 0% 30%, rgba(127,119,221,0.09) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-grid {
    position: relative; z-index: 1;
    width: 100%; max-width: 80rem; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  /* ─── Badge ─────────────────── */
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(45,212,191,0.08);
    border: 1px solid rgba(45,212,191,0.2);
    padding: 5px 12px; border-radius: var(--r-full);
    margin-bottom: 2rem;
    animation: heroFadeIn 500ms var(--ease-out) 60ms both;
  }
  .hero-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #2DD4BF;
    box-shadow: 0 0 0 3px rgba(45,212,191,0.15);
    flex-shrink: 0;
  }
  .hero-badge-label {
    font-size: 12px; letter-spacing: 0.06em;
    color: rgba(45,212,191,0.8);
    font-family: 'Poppins', sans-serif; font-weight: 500;
  }

  /* ─── Headline ───────────────── */
  .hero-headline {
    display: flex; gap: 1.5rem; align-items: stretch;
    margin-bottom: 2rem;
    animation: heroFadeIn 650ms var(--ease-out) 140ms both;
  }
  .hero-vbar {
    width: 3px;
    background: linear-gradient(to bottom, var(--accent) 60%, transparent 100%);
    border-radius: 2px; flex-shrink: 0;
  }
  .hero-h1 { font-family: 'Poppins', sans-serif; margin: 0; }
  .hero-h1-upper {
    display: block;
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: -0.02em; line-height: 1.1;
    margin-bottom: 0.05em;
  }
  .hero-h1-main {
    display: block;
    font-size: clamp(3.5rem, 6.5vw, 6.5rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.035em; line-height: 0.93;
  }
  .hero-h1-main .vdot { color: var(--accent); }
  .hero-h1-qualifier {
    display: block;
    font-size: clamp(1rem, 1.75vw, 1.3rem);
    font-weight: 400;
    color: var(--text-dim);
    margin-top: 0.85em;
  }

  /* ─── Body text ──────────────── */
  .hero-body {
    font-size: 1rem; color: var(--text-muted);
    line-height: 1.8; max-width: 440px;
    margin: 0 0 2rem;
    animation: heroFadeIn 600ms var(--ease-out) 230ms both;
  }

  /* ─── CTAs ───────────────────── */
  .hero-ctas {
    display: flex; gap: 12px; flex-wrap: wrap;
    margin-bottom: 2.5rem;
    animation: heroFadeIn 600ms var(--ease-out) 310ms both;
  }

  /* ─── Trust bar ──────────────── */
  .hero-trust {
    display: flex; gap: 2rem; flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    animation: heroFadeIn 600ms var(--ease-out) 380ms both;
  }
  .trust-item { display: flex; flex-direction: column; gap: 3px; }
  .trust-value {
    font-size: 1.375rem; font-weight: 700;
    color: var(--text);
    font-family: 'Poppins', sans-serif;
  }
  .trust-label { font-size: 11px; color: var(--text-dim); letter-spacing: 0.04em; }

  /* ─── Browser mockup ─────────── */
  .hero-mockup-wrap {
    position: relative;
    display: flex; justify-content: center; align-items: center;
    padding: 2rem 0;
    animation: heroFadeIn 900ms var(--ease-out) 180ms both;
  }
  .hero-mockup-wrap::before {
    content: '';
    position: absolute; inset: -20px;
    background: radial-gradient(ellipse at 50% 50%, rgba(127,119,221,0.16) 0%, transparent 65%);
    pointer-events: none;
  }
  .browser-frame {
    position: relative; z-index: 1;
    width: 100%; max-width: 520px;
    border-radius: 14px; overflow: hidden;
    border: 1px solid rgba(127,119,221,0.22);
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.03);
    transform: perspective(1100px) rotateY(-6deg) rotateX(3deg);
    transition: transform 400ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .browser-frame:hover { transform: perspective(1100px) rotateY(-2deg) rotateX(1deg); }
  }

  /* ─── Responsive ─────────────── */
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.5rem; }
    .browser-frame { transform: none; max-width: 100%; }
    .hero { padding: 6rem 6% 4rem; min-height: auto; }
  }
</style>

<section class="hero" id="main-content" aria-label="Startseite Hero">
  <div class="hero-grid">

    <!-- Text -->
    <div>
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        <span class="hero-badge-label">Offen für neue Projekte · Köln</span>
      </div>

      <div class="hero-headline">
        <div class="hero-vbar" aria-hidden="true"></div>
        <h1 class="hero-h1">
          <span class="hero-h1-upper">Dein digitaler</span>
          <span class="hero-h1-main">Auftritt<span class="vdot">.</span></span>
          <span class="hero-h1-qualifier">Von einer Person.</span>
        </h1>
      </div>

      <p class="hero-body">
        Webseiten, IT-Setup und Branding für KMU und Handwerksbetriebe in Köln —
        persönlich, direkt und ohne Agentur-Overhead.
      </p>

      <div class="hero-ctas">
        <a href="/kontakt" class="btn-primary">Kostenloses Erstgespräch</a>
        <a href="/portfolio" class="btn-outline">Portfolio ansehen</a>
