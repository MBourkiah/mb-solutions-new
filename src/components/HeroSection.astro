---
// Hero — Exaggerated Minimalism, warm cream, editorial
---

<style>
  .hero {
    background: var(--bg);
    min-height: 100svh;
    display: flex; align-items: center;
    padding: 5rem 5% 4rem;
    position: relative; overflow: hidden;
  }

  /* Subtle background texture dots */
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(28,26,23,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 80rem; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem; align-items: center;
  }

  /* ─── Left: Text ─────────────── */
  .hero-pill { animation: fadeUp 500ms var(--ease-out) 60ms both; }

  .hero-headline {
    margin: 1.75rem 0;
    animation: fadeUp 650ms var(--ease-out) 130ms both;
  }
  .hero-line {
    display: block;
    font-size: clamp(4rem, 8.5vw, 8rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.04em;
    line-height: 0.96;
  }
  .hero-line.accent { color: var(--accent); }
  .hero-line.light  { font-weight: 500; color: var(--text-2); font-size: clamp(2rem, 4vw, 3.75rem); }

  .hero-divider {
    width: 100%; height: 1px; background: var(--border-2);
    margin: 2rem 0;
    animation: fadeUp 500ms var(--ease-out) 220ms both;
  }

  .hero-sub {
    font-size: 1.0625rem; color: var(--text-2);
    line-height: 1.75; max-width: 44ch; margin: 0 0 2.25rem;
    animation: fadeUp 500ms var(--ease-out) 270ms both;
  }

  .hero-ctas {
    display: flex; gap: 10px; flex-wrap: wrap;
    animation: fadeUp 500ms var(--ease-out) 330ms both;
  }

  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 2.5rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
    animation: fadeUp 500ms var(--ease-out) 400ms both;
    flex-wrap: wrap;
  }
  .stat-val {
    display: block;
    font-family: 'Outfit', sans-serif; font-size: 1.75rem; font-weight: 700;
    color: var(--text); line-height: 1; letter-spacing: -0.03em;
  }
  .stat-label {
    font-size: 12px; color: var(--text-3); margin-top: 4px;
    letter-spacing: 0.02em;
  }

  /* ─── Right: Cards ───────────── */
  .hero-right {
    display: flex; flex-direction: column; gap: 14px;
    animation: fadeUp 800ms var(--ease-out) 200ms both;
  }

  .hero-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-md);
  }

  /* Availability card */
  .avail-card {
    border-top: 3px solid var(--accent);
  }
  .avail-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1rem;
  }
  .avail-title {
    font-family: 'Outfit', sans-serif; font-size: 0.9375rem; font-weight: 700;
    color: var(--text); letter-spacing: -0.02em;
  }
  .avail-badge {
    font-size: 11px; font-weight: 500; color: #16A34A;
    background: #F0FDF4; border: 1px solid #BBF7D0;
    padding: 3px 9px; border-radius: var(--r-full);
  }
  .avail-services { display: flex; flex-direction: column; gap: 8px; }
  .avail-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 8px 10px; border-radius: 8px; background: var(--bg);
  }
  .avail-row-name { font-size: 13px; color: var(--text-2); font-weight: 500; }
  .avail-row-tag {
    font-size: 11px; font-weight: 500; color: var(--accent);
    background: var(--accent-light); padding: 2px 8px; border-radius: var(--r-full);
  }

  /* Location card */
  .loc-card { padding: 1.25rem 1.5rem; }
  .loc-inner { display: flex; align-items: center; gap: 12px; }
  .loc-icon {
    width: 38px; height: 38px; border-radius: 9px;
    background: var(--accent-light); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
  }
  .loc-label { font-size: 11px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.08em; }
  .loc-name  { font-size: 0.9375rem; font-weight: 600; color: var(--text); font-family: 'Outfit', sans-serif; letter-spacing: -0.02em; }

  /* Verified card */
  .verified-card { padding: 1rem 1.5rem; }
  .verified-inner { display: flex; align-items: center; gap: 12px; }
  .verified-icon {
    width: 36px; height: 36px; border-radius: 9px;
    background: #F0FDF4; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .verified-text { font-size: 0.875rem; color: var(--text-2); line-height: 1.4; }
  .verified-text strong { color: var(--text); font-weight: 600; }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-right { order: -1; max-width: 420px; margin: 0 auto; }
    .hero { padding: 4rem 6% 3rem; min-height: auto; }
    .hero-line { font-size: clamp(3rem, 10vw, 5.5rem); }
  }
</style>

<section class="hero" id="main-content" aria-label="Startseite Hero">
  <div class="hero-inner">

    <!-- Left: Text content -->
    <div>
      <div class="hero-pill">
        <span class="pill">
          <span class="pill-dot" aria-hidden="true"></span>
          Verfügbar für neue Projekte
        </span>
      </div>

      <div class="hero-headline">
        <span class="hero-line">Dein</span>
        <span class="hero-line accent">digitaler</span>
        <span class="hero-line">Auftritt.</span>
        <span class="hero-line light">Von einer Person.</span>
      </div>

      <div class="hero-divider" aria-hidden="true"></div>

      <p class="hero-sub">
        Webseiten, IT-Setup und Branding für KMU und Handwerksbetriebe
        in Köln — persönlich, direkt und ohne Agentur-Overhead.
      </p>

      <div class="hero-ctas">
        <a href="/kontakt" class="btn-primary">Kostenloses Erstgespräch</a>
        <a href="/portfolio" class="btn-outline">
          Portfolio ansehen
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="hero-stats" aria-label="Kennzahlen">
        <div>
          <span class="stat-val">12+</span>
          <span class="stat-label">Projekte umgesetzt</span>
        </div>
        <div>
          <span class="stat-val">48h</span>
          <span class="stat-label">Antwortzeit</span>
        </div>
        <div>
          <span class="stat-val">5+</span>
          <span class="stat-label">Jahre Erfahrung</span>
        </div>
      </div>
    </div>

    <!-- Right: Info cards -->
    <div class="hero-right" aria-label="Übersicht">

      <div class="hero-card avail-card">
        <div class="avail-header">
          <span class="avail-title">Services</span>
          <span class="avail-badge">Verfügbar</span>
        </div>
        <div class="avail-services">
          <div class="avail-row">
            <span class="avail-row-name">Webdesign</span>
            <span class="avail-row-tag">Astro · Next.js</span>
          </div>
          <div class="avail-row">
            <span class="avail-row-name">IT-Services</span>
            <span class="avail-row-tag">Cloud · Setup</span>
          </div>
          <div class="avail-row">
            <span class="avail-row-name">Branding</span>
            <span class="avail-row-tag">Logo · CI</span>
          </div>
        </div>
      </div>

      <div class="hero-card loc-card">
        <div class="loc-inner">
          <div class="loc-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <div class="loc-label">Standort</div>
            <div class="loc-name">Köln, Deutschland</div>
          </div>
        </div>
      </div>

      <div class="hero-card verified-card">
        <div class="verified-inner">
          <div class="verified-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <path d="M22 4L12 14.01l-3-3"/>
            </svg>
          </div>
          <div class="verified-text">
            <strong>Direktbetreuung</strong><br/>
            Du sprichst mit dem Entwickler — kein Vermittler, keine Warteschlange.
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
