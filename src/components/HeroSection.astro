---
// Hero — Exaggerated Minimalism, warm cream, editorial
---

<style>
  .hero {
    background: var(--bg);
    min-height: 100svh;
    display: flex; align-items: center;
    padding: 5rem 5% 4rem;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(28,26,23,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  .hero-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 80rem; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 3rem; align-items: center;
  }

  /* ─── Left: Text ─────────────── */
  .hero-pill { animation: fadeUp 500ms var(--ease-out) 60ms both; }
  .hero-headline { margin: 1.75rem 0; animation: fadeUp 650ms var(--ease-out) 130ms both; }
  .hero-line {
    display: block; font-size: clamp(4rem, 8.5vw, 8rem);
    font-weight: 800; color: var(--text);
    letter-spacing: -0.04em; line-height: 0.96;
  }
  .hero-line.accent { color: var(--accent); }
  .hero-line.light  { font-weight: 500; color: var(--text-2); font-size: clamp(2rem, 4vw, 3.75rem); }

  .hero-divider {
    width: 100%; height: 1px; background: var(--border-2);
    margin: 2rem 0; animation: fadeUp 500ms var(--ease-out) 220ms both;
  }
  .hero-sub {
    font-size: 1.0625rem; color: var(--text-2);
    line-height: 1.75; max-width: 44ch; margin: 0 0 2.25rem;
    animation: fadeUp 500ms var(--ease-out) 270ms both;
  }
  .hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; animation: fadeUp 500ms var(--ease-out) 330ms both; }
  .hero-stats {
    display: flex; gap: 2.5rem; margin-top: 2.5rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
    animation: fadeUp 500ms var(--ease-out) 400ms both; flex-wrap: wrap;
  }
  .stat-val {
    display: block; font-family: 'Outfit', sans-serif; font-size: 1.75rem; font-weight: 700;
    color: var(--text); line-height: 1; letter-spacing: -0.03em;
  }
  .stat-label { font-size: 12px; color: var(--text-3); margin-top: 4px; letter-spacing: 0.02em; }

  /* ─── Right: Browser Mockup ───── */
  .hero-right {
    display: flex; flex-direction: column; gap: 14px;
    animation: fadeUp 800ms var(--ease-out) 200ms both;
  }

  .browser-mockup {
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(28,26,23,0.04);
    transform: rotate(1.5deg);
    transition: transform 400ms var(--ease-out), box-shadow 400ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .browser-mockup:hover {
      transform: rotate(0deg) scale(1.01);
      box-shadow: 0 24px 64px rgba(0,0,0,0.14), 0 0 0 1px rgba(28,26,23,0.04);
    }
  }

  .browser-topbar {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
  }
  .browser-dots { display: flex; gap: 6px; flex-shrink: 0; }
  .browser-dots span {
    width: 10px; height: 10px; border-radius: 50%; display: block;
  }
  .browser-url {
    flex: 1; background: var(--surface); border: 1px solid var(--border);
    border-radius: 6px; padding: 4px 10px;
    font-size: 11px; color: var(--text-3); font-weight: 500;
    letter-spacing: 0.01em; text-align: center;
  }

  .browser-img {
    display: block; width: 100%; height: 240px;
    object-fit: cover; object-position: top;
    transition: transform 6000ms ease;
  }
  @media (hover: hover) and (pointer: fine) {
    .browser-mockup:hover .browser-img { transform: translateY(-12%); }
  }

  /* Meta strip below browser */
  .hero-meta-strip {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 4px;
  }
  .hero-meta-loc {
    display: flex; align-items: center; gap: 5px;
    font-size: 12px; color: var(--text-3); font-weight: 500;
  }

  /* Project label on browser */
  .browser-label {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 12px 16px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: var(--shadow-sm);
  }
  .browser-label-left { display: flex; flex-direction: column; gap: 2px; }
  .browser-label-cat { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; }
  .browser-label-name { font-family: 'Outfit', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--text); letter-spacing: -0.02em; }
  .browser-label-tag {
    font-size: 10px; font-weight: 500; color: #D97706;
    background: #FFFBEB; border: 1px solid #FDE68A;
    padding: 3px 8px; border-radius: var(--r-full);
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-right { max-width: 480px; margin: 0 auto; width: 100%; }
    .hero { padding: 4rem 6% 3rem; min-height: auto; }
    .hero-line { font-size: clamp(3rem, 10vw, 5.5rem); }
    .browser-mockup { transform: none; }
  }
  @media (max-width: 480px) {
    .hero { padding: 3.5rem 5% 2.5rem; }
    .hero-inner { gap: 2rem; }
    .browser-img { height: 190px; }
    .hero-stats { gap: 1.5rem; margin-top: 2rem; padding-top: 1.5rem; }
    .hero-line { font-size: clamp(2.75rem, 11vw, 3.5rem); }
  }
</style>

<section class="hero" id="main-content" aria-label="Startseite Hero">
  <div class="hero-inner">

    <!-- Left: Text -->
    <div>
      <div class="hero-pill">
        <span class="pill">
          <span class="pill-dot" aria-hidden="true"></span>
          Verfügbar für neue Projekte
        </span>
      </div>

      <div class="hero-headline">
        <span class="hero-line">Dein</span>
        <span class="hero-line accent">digitaler</span>
        <span class="hero-line">Auftritt.</span>
        <span class="hero-line light">Von einer Person.</span>
      </div>

      <div class="hero-divider" aria-hidden="true"></div>

      <p class="hero-sub">
        Webseiten, IT-Setup und Branding für KMU und Handwerksbetriebe
        in Köln — persönlich, direkt und ohne Agentur-Overhead.
      </p>

      <div class="hero-ctas">
        <a href="/kontakt" class="btn-primary">Kostenloses Erstgespräch</a>
        <a href="/portfolio" class="btn-outline">
          Portfolio ansehen
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="hero-stats" aria-label="Kennzahlen">
        <div><span class="stat-val">12+</span><span class="stat-label">Projekte umgesetzt</span></div>
        <div><span class="stat-val">48h</span><span class="stat-label">Antwortzeit</span></div>
        <div><span class="stat-val">5+</span><span class="stat-label">Jahre Erfahrung</span></div>
      </div>
    </div>

    <!-- Right: Browser Mockup -->
    <div class="hero-right">
      <div class="browser-mockup">
        <div class="browser-topbar" aria-hidden="true">
          <div class="browser-dots">
            <span style="background:#FF5F57;"></span>
            <span style="background:#FFBD2E;"></span>
            <span style="background:#28C840;"></span>
          </div>
          <div class="browser-url">café-morgenrot.de</div>
        </div>
        <img
          src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=720&h=460&fit=crop&q=82&auto=format"
          alt="Beispiel-Kundenprojekt: Website für ein Kölner Café"
          class="browser-img"
          loading="eager"
          decoding="async"
          width="720"
          height="460"
        />
      </div>

      <div class="hero-meta-strip">
        <div class="browser-label" style="flex:1;">
          <div class="browser-label-left">
            <span class="browser-label-cat">Webdesign · Köln</span>
            <span class="browser-label-name">Café Morgenrot</span>
          </div>
          <span class="browser-label-tag">Fertiggestellt</span>
        </div>
      </div>

      <div style="display:flex;align-items:center;justify-content:center;gap:6px;padding:0 4px;">
        <div class="hero-meta-loc">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          Köln, Deutschland
        </div>
        <span style="color:var(--border-2);font-size:10px;">·</span>
        <div class="hero-meta-loc">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/>
          </svg>
          Direktbetreuung
        </div>
      </div>
    </div>

  </div>
</section>
