---
// No props – content is static copy for MB-Solutions
---

<section class="relative overflow-hidden min-h-[90vh] flex items-center bg-white">

  <!-- Decorative background blobs -->
  <div
    class="absolute -top-40 -right-28 w-[600px] h-[600px] rounded-full bg-primary opacity-[0.12] blur-3xl pointer-events-none select-none"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -bottom-32 -left-24 w-[480px] h-[480px] rounded-full bg-teal blur-3xl pointer-events-none select-none"
    aria-hidden="true"
  ></div>

  <!-- Main content -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 flex flex-col items-center text-center">

    <!-- 1. Badge -->
    <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-primary shrink-0" aria-hidden="true"></span>
      Webdesign &amp; IT aus Köln
    </div>

    <!-- 2. Headline -->
    <h1 class="text-4xl sm:text-5xl lg:text-[3.75rem] font-bold text-gray-900 leading-tight tracking-tight mb-6 max-w-3xl">
      Digitale Lösungen,<br />
      die wirklich&nbsp;<span
        class="inline-block bg-primary text-white px-3 py-1 rounded-xl whitespace-nowrap"
      >wirken.</span>
    </h1>

    <!-- 3. Subtext -->
    <p class="text-lg sm:text-xl text-gray-500 max-w-2xl leading-relaxed mb-10">
      Ich baue Webseiten, die Kunden gewinnen – und Brands, die in Erinnerung
      bleiben. Für Selbstständige &amp; KMU in Köln und deutschlandweit.
    </p>

    <!-- 4. CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center gap-4 mb-16 w-full sm:w-auto">
      <a
        href="/kontakt"
        class="w-full sm:w-auto inline-flex items-center justify-center px-7 py-3.5 rounded-xl bg-primary text-white text-base font-medium hover:bg-primary-dark transition-colors duration-150 shadow-sm"
      >
        Kostenloses Erstgespräch
      </a>
      <a
        href="/portfolio"
        class="w-full sm:w-auto inline-flex items-center justify-center px-7 py-3.5 rounded-xl border border-gray-200 text-gray-700 text-base font-medium hover:border-primary hover:text-primary transition-colors duration-150"
      >
        Portfolio ansehen →
      </a>
    </div>

    <!-- 5. Trust Bar -->
    <div class="w-full max-w-xl pt-8 border-t border-gray-100">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-0">

        <div class="flex flex-col items-center gap-0.5 sm:px-8">
          <span class="text-xl font-bold text-gray-900">3-in-1</span>
          <span class="text-sm text-gray-500">Leistungen aus einer Hand</span>
        </div>

        <div class="hidden sm:block w-px h-8 bg-gray-200" aria-hidden="true"></div>

        <div class="flex flex-col items-center gap-0.5 sm:px-8">
          <span class="text-xl font-bold text-gray-900">48h</span>
          <span class="text-sm text-gray-500">Antwortzeit garantiert</span>
        </div>

        <div class="hidden sm:block w-px h-8 bg-gray-200" aria-hidden="true"></div>

        <div class="flex flex-col items-center gap-0.5 sm:px-8">
          <span class="text-xl font-bold text-gray-900">Köln</span>
          <span class="text-sm text-gray-500">Persönlich vor Ort möglich</span>
        </div>

      </div>
    </div>

  </div>
</section>
