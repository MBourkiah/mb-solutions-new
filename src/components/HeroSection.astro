---
// No props – static hero for MB-Solutions
---

<!-- Keyframes must be global so inline SVG animation references resolve correctly -->
<style is:global>
  @keyframes float1 {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }
  @keyframes float2 {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-12px); }
  }
  @keyframes float3 {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-6px); }
  }
</style>

<style>
  /* Responsive headline: mobile → md+ */
  .hero-h1 {
    font-size: clamp(2rem, 8vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: #0f0f0f;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 768px) {
    .hero-h1 { font-size: clamp(2.5rem, 5vw, 4rem); }
  }

  /* CTA buttons */
  .cta-primary {
    background: #7F77DD;
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 200ms ease;
  }
  .cta-primary:hover { background: #6B63C9; }

  .cta-secondary {
    border: 1.5px solid #e5e7eb;
    background: #ffffff;
    color: #374151;
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color 200ms ease;
  }
  .cta-secondary:hover { border-color: #9ca3af; }
</style>

<section class="bg-white min-h-[90vh] flex items-center">
  <div class="w-full px-6 md:px-12 lg:px-20 pt-20 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-[55%_45%] gap-12 lg:gap-6 items-center">

      <!-- ═══ LEFT: Text Content ════════════════════════════════════ -->
      <div class="flex flex-col items-center lg:items-start text-center lg:text-left">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-violet-50 border border-violet-200 text-violet-700 text-xs font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-violet-500 shrink-0" aria-hidden="true"></span>
          Webdesign &amp; IT aus Köln
        </div>

        <!-- Headline -->
        <h1 class="hero-h1">
          Digitale Lösungen,<br />
          die wirklich <span style="color: #7F77DD;">wirken.</span>
        </h1>

        <!-- Subtext -->
        <p
          class="mb-10 mx-auto lg:mx-0"
          style="font-size: 1.0625rem; color: #6b7280; max-width: 420px; line-height: 1.75;"
        >
          Ich baue Webseiten, die Kunden gewinnen – und Brands, die in Erinnerung
          bleiben. Für KMU in Köln und deutschlandweit.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/kontakt" class="cta-primary">Kostenloses Erstgespräch</a>
          <a href="/portfolio" class="cta-secondary">Portfolio ansehen →</a>
        </div>

        <!-- Trust Bar -->
        <div class="mt-12 flex items-center">
          <div class="pr-5 text-center lg:text-left">
            <p class="text-sm font-semibold text-gray-900">3-in-1</p>
            <p class="text-xs text-gray-400 mt-0.5">Leistungen aus einer Hand</p>
          </div>
          <div class="w-px h-7 bg-gray-100 shrink-0"></div>
          <div class="px-5 text-center">
            <p class="text-sm font-semibold text-gray-900">48h</p>
            <p class="text-xs text-gray-400 mt-0.5">Antwortzeit garantiert</p>
          </div>
          <div class="w-px h-7 bg-gray-100 shrink-0"></div>
          <div class="pl-5 text-center lg:text-left">
            <p class="text-sm font-semibold text-gray-900">Köln</p>
            <p class="text-xs text-gray-400 mt-0.5">Persönlich vor Ort</p>
          </div>
        </div>

      </div>

      <!-- ═══ RIGHT: SVG Illustration (hidden < md) ═════════════════ -->
      <div class="hidden md:flex items-center justify-center">
        <!--
          viewBox 0 0 500 500
          Card 1 (top-left):   x=25  y=70  w=185 h=95
          Card 2 (mid-right):  x=250 y=185 w=210 h=115
          Card 3 (bot-left):   x=55  y=335 w=165 h=75
          Donut: cx=300 cy=242 r=26  C≈163
            Arc 1 (violet 50%=82px):  dashoffset=0
            Arc 2 (green  25%=41px):  dashoffset=81   [C-82]
            Arc 3 (orange 12%=20px):  dashoffset=40   [C-82-41]
        -->
        <svg
          viewBox="0 0 500 500"
          width="100%"
          height="auto"
          style="max-width: 480px;"
          aria-hidden="true"
          role="img"
        >
          <defs>
            <!-- Clip-paths keep card headers flush with rounded card corners -->
            <clipPath id="clip-c1">
              <rect x="25" y="70" width="185" height="95" rx="12"/>
            </clipPath>
            <clipPath id="clip-c3">
              <rect x="55" y="335" width="165" height="75" rx="12"/>
            </clipPath>
          </defs>

          <!-- ── Background circle ──────────────────────────────── -->
          <circle cx="250" cy="250" r="220" fill="#f5f3ff"/>

          <!-- ── Decorative ring (top-right) ───────────────────── -->
          <circle cx="440" cy="70" r="60" fill="none" stroke="#7F77DD" stroke-width="1" opacity="0.15"/>

          <!-- ── Connecting dashed lines ────────────────────────── -->
          <line x1="210" y1="117" x2="252" y2="232" stroke="#d1d5db" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="252" y1="248" x2="218" y2="334" stroke="#d1d5db" stroke-width="1" stroke-dasharray="4 4"/>

          <!-- ── Decorative dots ────────────────────────────────── -->
          <circle cx="216" cy="55"  r="5" fill="#7F77DD" opacity="0.3"/>
          <circle cx="420" cy="177" r="4" fill="#7F77DD" opacity="0.3"/>
          <circle cx="44"  cy="294" r="6" fill="#7F77DD" opacity="0.3"/>
          <circle cx="367" cy="379" r="4" fill="#7F77DD" opacity="0.3"/>
          <circle cx="463" cy="309" r="5" fill="#7F77DD" opacity="0.3"/>

          <!-- ── Decorative squares ─────────────────────────────── -->
          <rect x="172" y="296" width="8" height="8" rx="2" fill="#1D9E75" opacity="0.4"/>
          <rect x="393" y="128" width="8" height="8" rx="2" fill="#1D9E75" opacity="0.4"/>

          <!-- ═══════════════════════════════════════════════════════
               CARD 1 – top left  float1 4s
          ═══════════════════════════════════════════════════════ -->
          <g style="animation: float1 4s ease-in-out infinite;">
            <!-- Card background (no stroke so header clips clean) -->
            <rect x="25" y="70" width="185" height="95" rx="12" fill="white"/>
            <!-- Violet header, clipped to card shape -->
            <rect x="25" y="70" width="185" height="24" fill="#7F77DD" clip-path="url(#clip-c1)"/>
            <!-- Card border drawn last to appear on top -->
            <rect x="25" y="70" width="185" height="95" rx="12" fill="none" stroke="#e5e7eb" stroke-width="1"/>
            <!-- Text line placeholders -->
            <rect x="40" y="110" width="108" height="4" rx="2" fill="#e5e7eb"/>
            <rect x="40" y="119" width="76"  height="4" rx="2" fill="#f3f4f6"/>
            <rect x="40" y="128" width="92"  height="4" rx="2" fill="#f3f4f6"/>
            <!-- Live indicator -->
            <circle cx="40" cy="150" r="3.5" fill="#22c55e"/>
            <text x="50" y="154" font-size="8.5" fill="#22c55e" font-weight="500"
                  font-family="system-ui,-apple-system,sans-serif">Live</text>
          </g>

          <!-- ═══════════════════════════════════════════════════════
               CARD 2 – middle right  float2 5s 0.5s delay
          ═══════════════════════════════════════════════════════ -->
          <g style="animation: float2 5s ease-in-out infinite 0.5s;">
            <rect x="250" y="185" width="210" height="115" rx="12" fill="white" stroke="#e5e7eb" stroke-width="1"/>

            <!-- Donut chart: cx=300 cy=242 r=26 C≈163  stroke-width=10 -->
            <g transform="rotate(-90 300 242)">
              <!-- Arc 1: violet ~50% (82 of 163px) -->
              <circle cx="300" cy="242" r="26" fill="none"
                      stroke="#7F77DD" stroke-width="10"
                      stroke-dasharray="82 81"
                      stroke-dashoffset="0"
                      stroke-linecap="butt"/>
              <!-- Arc 2: green ~25% (41px), starts at 82 → dashoffset = 163-82 = 81 -->
              <circle cx="300" cy="242" r="26" fill="none"
                      stroke="#1D9E75" stroke-width="10"
                      stroke-dasharray="41 122"
                      stroke-dashoffset="81"
                      stroke-linecap="butt"/>
              <!-- Arc 3: orange ~12% (20px), starts at 123 → dashoffset = 163-123 = 40 -->
              <circle cx="300" cy="242" r="26" fill="none"
                      stroke="#F97316" stroke-width="10"
                      stroke-dasharray="20 143"
                      stroke-dashoffset="40"
                      stroke-linecap="butt"/>
            </g>

            <!-- Donut center label -->
            <text x="300" y="246" text-anchor="middle" font-size="10" font-weight="700"
                  fill="#111827" font-family="system-ui,-apple-system,sans-serif">82%</text>

            <!-- Text lines right of donut -->
            <rect x="344" y="207" width="73" height="5" rx="2" fill="#e5e7eb"/>
            <rect x="344" y="217" width="53" height="5" rx="2" fill="#f3f4f6"/>
            <rect x="344" y="232" width="79" height="5" rx="2" fill="#e5e7eb"/>
            <rect x="344" y="242" width="58" height="5" rx="2" fill="#f3f4f6"/>
            <rect x="344" y="257" width="40" height="5" rx="2" fill="#f9fafb"/>
          </g>

          <!-- ═══════════════════════════════════════════════════════
               CARD 3 – bottom left (violet fill)  float3 3.5s 1s delay
          ═══════════════════════════════════════════════════════ -->
          <g style="animation: float3 3.5s ease-in-out infinite 1s;">
            <!-- Violet card background -->
            <rect x="55" y="335" width="165" height="75" rx="12" fill="#7F77DD"/>
            <!-- Subtle darker border for depth -->
            <rect x="55" y="335" width="165" height="75" rx="12" fill="none" stroke="#6B63C9" stroke-width="1"/>
            <!-- Checkmark circle -->
            <circle cx="88" cy="372" r="16" fill="rgba(255,255,255,0.18)"/>
            <!-- Checkmark path -->
            <path d="M82 372 L86.5 377 L96 364"
                  stroke="white" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round"
                  fill="none"/>
            <!-- Card text -->
            <text x="113" y="368" font-size="10" font-weight="600"
                  fill="white" font-family="system-ui,-apple-system,sans-serif">Projekt</text>
            <text x="113" y="382" font-size="10" font-weight="400"
                  fill="rgba(255,255,255,0.8)" font-family="system-ui,-apple-system,sans-serif">abgeschlossen</text>
          </g>

        </svg>
      </div>

    </div>
  </div>
</section>
