---
// HeroSection — Editorial dark hero
// Signature: vertikale violette Akzentlinie + Werkstatt-Preisboard rechts
---

<style>
  .hero-root {
    min-height: 100vh;
    background: #0a0a0f;
    display: flex;
    align-items: center;
    padding: 7rem 8% 5rem;
    position: relative;
    overflow: hidden;
  }

  /* Hintergrundflächen — dezent */
  .hero-root::before {
    content: '';
    position: absolute;
    top: -15%; left: -10%;
    width: 65%; height: 90%;
    background: radial-gradient(ellipse at 0% 0%, rgba(127,119,221,0.07) 0%, transparent 60%);
    pointer-events: none;
  }
  .hero-root::after {
    content: '';
    position: absolute;
    bottom: 0; right: 0;
    width: 40%; height: 50%;
    background: radial-gradient(ellipse at 100% 100%, rgba(29,158,117,0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Grid: Text links, Preisboard rechts */
  .hero-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 72rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 5rem;
    align-items: center;
  }

  /* ─── Badge ─────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 2.75rem;
    animation: heroFadeIn 500ms var(--ease-out) 60ms both;
  }
  .hero-badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #2DD4BF;
    box-shadow: 0 0 0 3px rgba(45,212,191,0.15);
    flex-shrink: 0;
  }
  .hero-badge-text {
    font-size: 12px;
    letter-spacing: 0.07em;
    color: rgba(240,239,255,0.35);
  }

  /* ─── Headline mit vertikaler Akzentlinie ────────── */
  .hero-headline-wrap {
    display: flex;
    gap: 1.75rem;
    align-items: stretch;
    margin-bottom: 2rem;
    animation: heroFadeIn 650ms var(--ease-out) 140ms both;
  }
  /* Das Signature-Element: die violette vertikale Linie */
  .hero-vbar {
    width: 2px;
    background: linear-gradient(to bottom, #7F77DD 60%, rgba(127,119,221,0) 100%);
    flex-shrink: 0;
    border-radius: 1px;
  }
  .hero-h1 {
    font-family: 'Syne', system-ui, sans-serif;
    margin: 0;
  }
  .hero-h1-upper {
    display: block;
    font-size: clamp(1.875rem, 4vw, 3.5rem);
    font-weight: 700;
    color: rgba(240,239,255,0.55);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.05em;
  }
  .hero-h1-main {
    display: block;
    font-size: clamp(3.75rem, 8vw, 7.5rem);
    font-weight: 800;
    color: #F0EFFF;
    letter-spacing: -0.035em;
    line-height: 0.92;
  }
  /* Violetter Punkt als Micro-Signature */
  .hero-h1-main .vdot { color: #7F77DD; }
  .hero-h1-qualifier {
    display: block;
    font-size: clamp(1rem, 1.8vw, 1.375rem);
    font-weight: 400;
    color: rgba(240,239,255,0.32);
    letter-spacing: 0.01em;
    margin-top: 0.85em;
  }

  /* ─── Fließtext ──────────────────────────────────── */
  .hero-body {
    font-size: 1rem;
    color: rgba(240,239,255,0.5);
    line-height: 1.8;
    max-width: 460px;
    margin: 0 0 2.5rem;
    animation: heroFadeIn 600ms var(--ease-out) 230ms both;
  }

  /* ─── CTAs ───────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    animation: heroFadeIn 600ms var(--ease-out) 310ms both;
  }
  .hero-cta-primary {
    display: inline-flex; align-items: center;
    background: #7F77DD; color: #fff;
    padding: 13px 26px;
    border-radius: 100px;
    font-size: 14px; font-weight: 600;
    text-decoration: none;
    transition: background 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .hero-cta-primary:active { transform: scale(0.97); }
  @media (hover: hover) and (pointer: fine) {
    .hero-cta-primary:hover { background: #6B63C9; }
  }
  .hero-cta-secondary {
    display: inline-flex; align-items: center;
    background: transparent; color: rgba(240,239,255,0.55);
    padding: 13px 26px;
    border-radius: 100px;
    border: 1px solid rgba(240,239,255,0.1);
    font-size: 14px;
    text-decoration: none;
    transition: border-color 160ms var(--ease-out), color 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .hero-cta-secondary:active { transform: scale(0.97); }
  @media (hover: hover) and (pointer: fine) {
    .hero-cta-secondary:hover {
      border-color: rgba(240,239,255,0.22);
      color: #F0EFFF;
    }
  }

  /* Nur mobile: schmale Service-Zeile unterhalb CTAs */
  .hero-mobile-services {
    display: none;
    margin-top: 2rem;
    font-size: 12px;
    letter-spacing: 0.05em;
    color: rgba(240,239,255,0.22);
    animation: heroFadeIn 600ms var(--ease-out) 380ms both;
  }

  /* ─── Werkstatt-Preisboard ───────────────────────── */
  .hero-panel {
    background: #0e0e1c;
    border: 1px solid rgba(127,119,221,0.14);
    border-radius: 20px;
    padding: 1.875rem 2rem 1.625rem;
    animation: heroFadeIn 700ms var(--ease-out) 200ms both;
  }
  .hero-panel-label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(240,239,255,0.22);
    margin-bottom: 1.375rem;
  }

  /* Dotted-Leader Preiszeile */
  .price-row {
    display: flex;
    align-items: center;
    padding: 0.8125rem 0;
    border-bottom: 1px solid rgba(127,119,221,0.07);
  }
  .price-row:last-of-type { border-bottom: none; }
  .price-name {
    font-size: 13.5px;
    color: rgba(240,239,255,0.68);
    font-weight: 500;
    flex-shrink: 0;
  }
  /* Gestrichelte Linie als Verbindung */
  .price-dots {
    flex: 1;
    height: 1px;
    background-image: repeating-linear-gradient(
      to right,
      rgba(127,119,221,0.2) 0px,
      rgba(127,119,221,0.2) 2px,
      transparent 2px,
      transparent 8px
    );
    margin: 0 10px;
  }
  .price-value {
    font-size: 12.5px;
    color: rgba(240,239,255,0.32);
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  .hero-panel-rule {
    height: 1px;
    background: rgba(127,119,221,0.09);
    margin: 1.25rem 0;
  }
  .hero-panel-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .panel-loc {
    font-size: 11px;
    color: rgba(240,239,255,0.22);
  }
  .panel-avail {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    color: rgba(45,212,191,0.65);
  }
  .avail-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: #2DD4BF;
    flex-shrink: 0;
  }

  /* ─── Responsive ─────────────────────────────────── */
  @media (max-width: 960px) {
    .hero-inner { grid-template-columns: 1fr; gap: 0; }
    .hero-panel { display: none; }
    .hero-mobile-services { display: block; }
    .hero-root { padding: 6rem 6% 4rem; min-height: auto; }
  }
  @media (max-width: 480px) {
    .hero-badge { margin-bottom: 2rem; }
    .hero-headline-wrap { gap: 1.25rem; }
  }
</style>

<section class="hero-root">
  <div class="hero-inner">

    <!-- ══ LINKS: Editorial Text ══════════════════════ -->
    <div>
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        <span class="hero-badge-text">Offen für neue Projekte · Köln</span>
      </div>

      <div class="hero-headline-wrap">
        <div class="hero-vbar" aria-hidden="true"></div>
        <h1 class="hero-h1">
          <span class="hero-h1-upper">Dein digitaler</span>
          <span class="hero-h1-main">Auftritt<span class="vdot">.</span></span>
          <span class="hero-h1-qualifier">Von einer Person.</span>
        </h1>
      </div>

      <p class="hero-body">
        Webseiten, IT-Setup und Branding für KMU und Handwerksbetriebe in Köln —
        persönlich, direkt und ohne Agentur-Overhead.
      </p>

      <div class="hero-ctas">
        <a href="/kontakt" class="hero-cta-primary">Kostenloses Erstgespräch</a>
        <a href="/portfolio" class="hero-cta-secondary">Portfolio ansehen →</a>
      </div>

      <p class="hero-mobile-services">
        Webdesign &nbsp;·&nbsp; IT-Services &nbsp;·&nbsp; Branding
      </p>
    </div>

    <!-- ══ RECHTS: Werkstatt-Preisboard ══════════════ -->
    <aside class="hero-panel" aria-label="Leistungen und Preise">
      <p class="hero-panel-label">Leistungen</p>

      <div class="price-row">
        <span class="price-name">Webdesign</span>
        <span class="price-dots" aria-hidden="true"></span>
        <span class="price-value">ab 499 €</span>
      </div>
      <div class="price-row">
        <span class="price-name">IT-Services</span>
        <span class="price-dots" aria-hidden="true"></span>
        <span class="price-value">ab 45 €/Std.</span>
      </div>
      <div class="price-row">
        <span class="price-name">Branding</span>
        <span class="price-dots" aria-hidden="true"></span>
        <span class="price-value">ab 149 €</span>
      </div>
      <div class="price-row">
        <span class="price-name">Komplettpaket</span>
        <span class="price-dots" aria-hidden="true"></span>
        <span class="price-value">auf Anfrage</span>
      </div>

      <div class="hero-panel-rule" aria-hidden="true"></div>

      <div class="hero-panel-footer">
        <span class="panel-loc">📍 Köln</span>
        <span class="panel-avail">
          <span class="avail-dot"></span>
          Verfügbar
        </span>
      </div>
    </aside>

  </div>
</section>
