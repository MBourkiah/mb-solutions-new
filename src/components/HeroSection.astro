---
// Dark-theme hero – MB-Solutions
---

<!-- Keyframes global so SVG <g> style="animation:..." resolves.
     Float animations use ease-in-out (on-screen ambient motion = correct per Emil's framework). -->
<style is:global>
  @keyframes float1 {
    0%, 100% { transform: translate(40px, 40px); }
    50%       { transform: translate(40px, 30px); }
  }
  @keyframes float2 {
    0%, 100% { transform: translate(260px, 170px); }
    50%       { transform: translate(260px, 158px); }
  }
  @keyframes float3 {
    0%, 100% { transform: translate(60px, 310px); }
    50%       { transform: translate(60px, 302px); }
  }
</style>

<style>
  .hero-section {
    min-height: 100vh;
    background: #0a0a0f;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 0 5% 0 8%;
    gap: 4rem;
    position: relative;
    overflow: hidden;
  }

  /* ── Entrance animations (above the fold: keyframe-based) ── */
  .hero-badge-wrap {
    animation: heroFadeIn 600ms var(--ease-out) 80ms both;
  }
  .hero-h1 {
    font-size: clamp(2.8rem, 4vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #ffffff;
    margin: 0 0 1.5rem;
    animation: heroFadeIn 700ms var(--ease-out) 180ms both;
  }
  .hero-sub-wrap {
    animation: heroFadeIn 700ms var(--ease-out) 280ms both;
  }
  .hero-ctas-wrap {
    animation: heroFadeIn 700ms var(--ease-out) 360ms both;
  }
  .hero-trust {
    margin-top: 3rem;
    display: flex;
    gap: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    animation: heroFadeIn 700ms var(--ease-out) 440ms both;
  }
  .hero-illustration {
    width: 100%; max-width: 520px;
    margin-left: auto;
    position: relative; z-index: 1;
    animation: heroFadeIn 900ms var(--ease-out) 200ms both;
  }

  /* ── CTA buttons ─── */
  .hero-cta-primary {
    background: #7F77DD;
    color: #ffffff;
    padding: 14px 28px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    border: none;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: background 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .hero-cta-primary:active { transform: scale(0.97); }

  .hero-cta-secondary {
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    padding: 14px 28px;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    font-size: 14px;
    font-weight: 400;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: border-color 160ms var(--ease-out), transform 160ms var(--ease-out);
  }
  .hero-cta-secondary:active { transform: scale(0.97); }

  /* Hover: only on devices that support it (not touch) */
  @media (hover: hover) and (pointer: fine) {
    .hero-cta-primary:hover  { background: #6B63C9; }
    .hero-cta-secondary:hover { border-color: rgba(255, 255, 255, 0.4); }
  }

  @media (max-width: 768px) {
    .hero-section {
      grid-template-columns: 1fr;
      padding: 6rem 6% 3rem;
      min-height: auto;
    }
    .hero-h1 { font-size: clamp(2.2rem, 8vw, 3rem); }
    .hero-illustration { display: none; }
    .hero-trust { gap: 1.5rem !important; }
  }
</style>

<section class="hero-section">

  <!-- Background blobs -->
  <div aria-hidden="true" style="
    position:absolute; pointer-events:none; border-radius:50%;
    width:600px; height:600px;
    background:radial-gradient(circle, rgba(127,119,221,0.15) 0%, transparent 70%);
    top:-200px; left:-200px;
  "></div>
  <div aria-hidden="true" style="
    position:absolute; pointer-events:none; border-radius:50%;
    width:400px; height:400px;
    background:radial-gradient(circle, rgba(29,158,117,0.08) 0%, transparent 70%);
    bottom:-100px; right:0;
  "></div>

  <!-- ══ LEFT: Text ══════════════════════════════════════════ -->
  <div style="position:relative; z-index:1; padding:6rem 0;">

    <!-- Badge -->
    <div class="hero-badge-wrap">
      <div style="
        display:inline-flex; align-items:center; gap:8px;
        background:rgba(127,119,221,0.15);
        border:1px solid rgba(127,119,221,0.3);
        padding:6px 14px; border-radius:100px;
        margin-bottom:2rem;
      ">
        <span style="width:6px;height:6px;border-radius:50%;background:#7F77DD;flex-shrink:0;"></span>
        <span style="color:#AFA9EC;font-size:13px;">Webdesign &amp; IT aus Köln</span>
      </div>
    </div>

    <!-- Headline -->
    <h1 class="hero-h1">
      Digitale Lösungen,<br />
      die wirklich<br />
      <span style="color:#7F77DD;">wirken.</span>
    </h1>

    <!-- Subtext -->
    <div class="hero-sub-wrap">
      <p style="
        font-size:1.0625rem;
        color:rgba(255,255,255,0.5);
        line-height:1.8;
        max-width:400px;
        margin:0 0 2.5rem;
      ">
        Ich baue Webseiten, die Kunden gewinnen – und Brands,
        die in Erinnerung bleiben. Für KMU in Köln und deutschlandweit.
      </p>
    </div>

    <!-- CTAs -->
    <div class="hero-ctas-wrap">
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/kontakt" class="hero-cta-primary">Kostenloses Erstgespräch</a>
        <a href="/portfolio" class="hero-cta-secondary">Portfolio ansehen →</a>
      </div>
    </div>

    <!-- Trust Bar -->
    <div class="hero-trust">
      <div>
        <p style="font-size:1.5rem;font-weight:600;color:white;margin:0;">3-in-1</p>
        <p style="font-size:12px;color:rgba(255,255,255,0.35);margin-top:4px;">Leistungen aus einer Hand</p>
      </div>
      <div>
        <p style="font-size:1.5rem;font-weight:600;color:white;margin:0;">48h</p>
        <p style="font-size:12px;color:rgba(255,255,255,0.35);margin-top:4px;">Antwortzeit garantiert</p>
      </div>
      <div>
        <p style="font-size:1.5rem;font-weight:600;color:white;margin:0;">Köln</p>
        <p style="font-size:12px;color:rgba(255,255,255,0.35);margin-top:4px;">Persönlich vor Ort</p>
      </div>
    </div>

  </div>

  <!-- ══ RIGHT: SVG Illustration ═════════════════════════════ -->
  <div class="hero-illustration">
    <svg viewBox="0 0 520 480" width="100%" height="auto" aria-hidden="true" role="img">

      <circle cx="260" cy="240" r="210"
        fill="rgba(127,119,221,0.06)"
        stroke="rgba(127,119,221,0.1)" stroke-width="1"/>
      <circle cx="260" cy="240" r="230"
        fill="none"
        stroke="rgba(127,119,221,0.06)" stroke-width="1"
        stroke-dasharray="4 8"/>

      <line x1="220" y1="100" x2="270" y2="175"
        stroke="rgba(127,119,221,0.2)" stroke-width="1" stroke-dasharray="3 6"/>
      <line x1="270" y1="305" x2="165" y2="315"
        stroke="rgba(127,119,221,0.2)" stroke-width="1" stroke-dasharray="3 6"/>

      <circle cx="68"  cy="22"  r="3" fill="#7F77DD" opacity="0.3"/>
      <circle cx="445" cy="82"  r="4" fill="#7F77DD" opacity="0.3"/>
      <circle cx="28"  cy="288" r="5" fill="#7F77DD" opacity="0.3"/>
      <circle cx="372" cy="402" r="3" fill="#7F77DD" opacity="0.3"/>
      <circle cx="472" cy="272" r="4" fill="#7F77DD" opacity="0.3"/>
      <circle cx="198" cy="458" r="3" fill="#7F77DD" opacity="0.25"/>

      <!-- Card 1: Website Preview — float1 5s ease-in-out -->
      <g style="animation: float1 5s cubic-bezier(0.45,0.05,0.55,0.95) infinite;">
        <rect x="0" y="0" width="220" height="130" rx="14"
          fill="#1a1a2e" stroke="rgba(127,119,221,0.3)" stroke-width="1"/>
        <path d="M14,0 L206,0 C214,0 220,6 220,14 L220,32 L0,32 L0,14 C0,6 6,0 14,0 Z"
          fill="#7F77DD"/>
        <circle cx="14" cy="16" r="4" fill="rgba(255,255,255,0.4)"/>
        <circle cx="26" cy="16" r="4" fill="rgba(255,255,255,0.4)"/>
        <circle cx="38" cy="16" r="4" fill="rgba(255,255,255,0.4)"/>
        <rect x="14" y="48" width="132" height="6" rx="3" fill="rgba(255,255,255,0.08)"/>
        <rect x="14" y="62" width="88"  height="6" rx="3" fill="rgba(255,255,255,0.08)"/>
        <rect x="14" y="76" width="112" height="6" rx="3" fill="rgba(255,255,255,0.08)"/>
        <rect x="14" y="90" width="68"  height="6" rx="3" fill="rgba(255,255,255,0.08)"/>
        <circle cx="14" cy="115" r="4" fill="#1D9E75"/>
        <text x="24" y="119" font-size="10" fill="rgba(255,255,255,0.4)"
          font-family="system-ui,-apple-system,sans-serif">Live</text>
      </g>

      <!-- Card 2: Analytics / Donut — float2 6s delay 0.8s -->
      <g style="animation: float2 6s cubic-bezier(0.45,0.05,0.55,0.95) infinite 0.8s;">
        <rect x="0" y="0" width="210" height="140" rx="14"
          fill="#12122a" stroke="rgba(127,119,221,0.2)" stroke-width="1"/>
        <!-- Donut: C=2π×35≈220; positive dashoffset = C−arc_start -->
        <g transform="rotate(-90 50 70)">
          <circle cx="50" cy="70" r="35" fill="none" stroke="#7F77DD" stroke-width="8"
            stroke-dasharray="66 154" stroke-dashoffset="0" stroke-linecap="butt"/>
          <circle cx="50" cy="70" r="35" fill="none" stroke="#1D9E75" stroke-width="8"
            stroke-dasharray="44 176" stroke-dashoffset="154" stroke-linecap="butt"/>
          <circle cx="50" cy="70" r="35" fill="none" stroke="#D85A30" stroke-width="8"
            stroke-dasharray="44 176" stroke-dashoffset="110" stroke-linecap="butt"/>
        </g>
        <text x="50" y="74" text-anchor="middle" font-size="11" font-weight="600" fill="white"
          font-family="system-ui,-apple-system,sans-serif">82%</text>
        <rect x="102" y="42" width="60" height="5" rx="2" fill="rgba(255,255,255,0.08)"/>
        <rect x="102" y="52" width="40" height="5" rx="2" fill="rgba(255,255,255,0.06)"/>
        <rect x="102" y="67" width="60" height="5" rx="2" fill="rgba(255,255,255,0.08)"/>
        <rect x="102" y="77" width="42" height="5" rx="2" fill="rgba(255,255,255,0.06)"/>
        <rect x="102" y="92" width="52" height="5" rx="2" fill="rgba(255,255,255,0.08)"/>
        <rect x="102" y="102" width="34" height="5" rx="2" fill="rgba(255,255,255,0.06)"/>
      </g>

      <!-- Card 3: Success — float3 4s delay 0.3s -->
      <g style="animation: float3 4s cubic-bezier(0.45,0.05,0.55,0.95) infinite 0.3s;">
        <rect x="0" y="0" width="190" height="80" rx="14" fill="#7F77DD"/>
        <circle cx="28" cy="40" r="18" fill="rgba(255,255,255,0.2)"/>
        <path d="M20,40 L26,46 L36,34"
          stroke="white" stroke-width="2.5"
          stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <text x="56" y="33" font-size="11" font-weight="600" fill="white"
          font-family="system-ui,-apple-system,sans-serif">Projekt</text>
        <text x="56" y="48" font-size="11" font-weight="600" fill="white"
          font-family="system-ui,-apple-system,sans-serif">abgeschlossen</text>
        <text x="56" y="63" font-size="10" fill="rgba(255,255,255,0.6)"
          font-family="system-ui,-apple-system,sans-serif">mb-solutions.biz</text>
      </g>

    </svg>
  </div>

</section>
