<style>
  .cta-section { background: var(--bg); padding: 6rem 5% 8rem; }
  .cta-inner { max-width: 80rem; margin: 0 auto; }

  .cta-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 28px; padding: 5rem 6rem;
    display: flex; justify-content: space-between; align-items: center;
    gap: 3rem; flex-wrap: wrap;
    box-shadow: var(--shadow-lg); position: relative; overflow: hidden;
  }
  .cta-card::before {
    content: ''; position: absolute; top: -60px; left: -40px;
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(127,119,221,0.18) 0%, transparent 65%);
    pointer-events: none;
    animation: gradientGlow 7s ease-in-out infinite;
  }
  .cta-card::after {
    content: ''; position: absolute; top: 0; right: 0;
    width: 240px; height: 200px;
    background-image: radial-gradient(circle, rgba(28,26,23,0.06) 1px, transparent 1px);
    background-size: 20px 20px; pointer-events: none;
  }

  .cta-text { position: relative; z-index: 1; }
  .cta-h2 {
    font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 800;
    letter-spacing: -0.04em; color: var(--text); line-height: 1.1; margin-bottom: 1rem;
  }
  .cta-sub { font-size: 1.0625rem; color: var(--text-2); line-height: 1.7; max-width: 46ch; }

  .cta-actions {
    display: flex; flex-direction: column; gap: 12px;
    align-items: flex-start; position: relative; z-index: 1; flex-shrink: 0;
  }
  .cta-btns { display: flex; gap: 10px; flex-wrap: wrap; }
  .cta-note { font-size: 12px; color: var(--text-3); display: flex; align-items: center; gap: 6px; }
  .cta-note-dot { width: 5px; height: 5px; border-radius: 50%; background: #22C55E; flex-shrink: 0; }

  @media (max-width: 860px) {
    .cta-card { padding: 3.5rem 2.5rem; flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 599px) {
    .cta-section { padding: 4rem 5% 5rem; }
    .cta-card { padding: 2.5rem 1.75rem; border-radius: 20px; }
    .cta-btns { flex-direction: column; width: 100%; }
    .cta-btns .btn-primary, .cta-btns .btn-outline { justify-content: center; width: 100%; }
  }
</style>

<section class="cta-section" aria-labelledby="cta-heading">
  <div class="cta-inner">
    <div class="cta-card reveal">
      <div class="cta-text">
        <div class="eyebrow" style="margin-bottom:1.25rem;">
          <span class="eyebrow-bar" aria-hidden="true"></span>
          Kontakt
        </div>
        <h2 class="cta-h2" id="cta-heading">
          Bereit für deinen<br/>neuen Auftritt?
        </h2>
        <p class="cta-sub">
          Kostenloses Erstgespräch — kein Verkaufsdruck, keine
          Pflichten. Einfach erzählen, was du brauchst.
        </p>
      </div>
      <div class="cta-actions">
        <div class="cta-btns">
          <a href="/kontakt" class="btn-primary">
            Gespräch anfragen
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
              <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="mailto:mbourkiah@mb-solutions.biz" class="btn-outline">E-Mail schreiben</a>
        </div>
        <div class="cta-note">
          <span class="cta-note-dot" aria-hidden="true"></span>
          Antwortet innerhalb von 48 Stunden
        </div>
      </div>
    </div>
  </div>
</section>
