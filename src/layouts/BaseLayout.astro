---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'MB-Solutions – Webdesign, IT-Services und Branding für KMU und Handwerksbetriebe in Köln.',
  ogImage = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1200&h=630&fit=crop&q=80&auto=format',
} = Astro.props;

const canonical = `https://www.mb-solutions.biz${Astro.url.pathname}`;
const fullTitle = `${title} | MB-Solutions`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Primary meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MB-Solutions" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <!-- Resource hints -->
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Page-specific head content (schema, preloads, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <!-- Custom cursor (desktop only) -->
    <div id="mb-cursor" aria-hidden="true"></div>

    <!-- Skip link -->
    <a
      href="#main-content"
      style="position:absolute;left:-9999px;top:4px;z-index:10000;background:var(--accent);color:#fff;padding:8px 16px;border-radius:var(--r-md);font-size:14px;font-weight:600;text-decoration:none;"
      onfocus="this.style.left='4px'"
      onblur="this.style.left='-9999px'"
    >Zum Hauptinhalt springen</a>

    <slot />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/491718165966"
      target="_blank"
      rel="noopener noreferrer"
      id="wa-btn"
      aria-label="Per WhatsApp schreiben"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
      </svg>
      <span class="wa-label">WhatsApp</span>
    </a>

    <style>
      #wa-btn {
        position: fixed; bottom: 24px; right: 24px; z-index: 9000;
        display: flex; align-items: center; gap: 8px;
        background: #25D366; color: white;
        border-radius: 50px; padding: 13px 13px;
        box-shadow: 0 4px 16px rgba(37,211,102,0.40);
        text-decoration: none;
        transition: transform 220ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 220ms ease-out, padding 220ms ease-out;
        overflow: hidden; max-width: 52px;
      }
      #wa-btn:hover {
        transform: scale(1.06);
        box-shadow: 0 6px 24px rgba(37,211,102,0.50);
        padding: 13px 18px;
        max-width: 180px;
      }
      .wa-label {
        font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600;
        white-space: nowrap; opacity: 0; max-width: 0;
        transition: opacity 180ms ease-out 60ms, max-width 220ms ease-out;
        overflow: hidden;
      }
      #wa-btn:hover .wa-label { opacity: 1; max-width: 100px; }
    </style>

    <script is:inline>
      /* Custom cursor */
      (function () {
        var cur = document.getElementById('mb-cursor');
        if (!cur) return;
        document.addEventListener('mousemove', function (e) {
          cur.style.left = e.clientX + 'px';
          cur.style.top  = e.clientY + 'px';
        });
        document.addEventListener('mousedown', function () { cur.classList.add('clicking'); });
        document.addEventListener('mouseup',   function () { cur.classList.remove('clicking'); });
        document.querySelectorAll('a,button,[role="button"]').forEach(function (el) {
          el.addEventListener('mouseenter', function () { cur.classList.add('hovering'); });
          el.addEventListener('mouseleave', function () { cur.classList.remove('hovering'); });
        });
      })();

      /* Scroll reveal via IntersectionObserver */
      (function () {
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '-12px 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>
