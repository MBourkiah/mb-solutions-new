---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'MB-Solutions – Webdesign, IT-Services und Branding für KMU und Handwerksbetriebe in Köln.',
  ogImage = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1200&h=630&fit=crop&q=80&auto=format',
} = Astro.props;

const canonical = `https://www.mb-solutions.biz${Astro.url.pathname}`;
const fullTitle = `${title} | MB-Solutions`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Primary meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MB-Solutions" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <!-- Resource hints -->
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Page-specific head content (schema, preloads, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <!-- Custom cursor (desktop only) -->
    <div id="mb-cursor" aria-hidden="true"></div>

    <!-- Skip link -->
    <a
      href="#main-content"
      style="position:absolute;left:-9999px;top:4px;z-index:10000;background:var(--accent);color:#fff;padding:8px 16px;border-radius:var(--r-md);font-size:14px;font-weight:600;text-decoration:none;"
      onfocus="this.style.left='4px'"
      onblur="this.style.left='-9999px'"
    >Zum Hauptinhalt springen</a>

    <slot />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/491718165966"
      target="_blank"
      rel="noopener noreferrer"
      id="wa-btn"
      aria-label="Per WhatsApp schreiben"
      title="Per WhatsApp schreiben"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 32 32" fill="white" aria-hidden="true">
        <path d="M16 2C8.268 2 2 8.268 2 16c0 2.492.655 4.835 1.802 6.865L2 30l7.335-1.775A13.94 13.94 0 0 0 16 30c7.732 0 14-6.268 14-14S23.732 2 16 2zm0 25.6a11.54 11.54 0 0 1-5.88-1.607l-.422-.25-4.353 1.052 1.083-4.232-.277-.437A11.537 11.537 0 0 1 4.4 16C4.4 9.593 9.593 4.4 16 4.4S27.6 9.593 27.6 16 22.407 27.6 16 27.6zm6.33-8.63c-.347-.173-2.051-1.012-2.37-1.128-.318-.116-.55-.173-.78.174-.232.347-.897 1.128-1.1 1.36-.202.231-.405.26-.752.087-.347-.174-1.464-.54-2.788-1.72-1.031-.92-1.727-2.056-1.93-2.403-.202-.347-.022-.535.152-.707.156-.156.347-.405.52-.608.174-.202.232-.347.347-.578.116-.232.058-.434-.03-.607-.087-.174-.78-1.882-1.07-2.577-.281-.675-.567-.583-.78-.595l-.665-.012c-.232 0-.607.087-.925.434-.318.347-1.214 1.186-1.214 2.892s1.243 3.354 1.416 3.586c.174.231 2.447 3.735 5.93 5.24.829.358 1.476.572 1.98.731.832.265 1.59.228 2.189.138.667-.099 2.051-.839 2.342-1.65.29-.81.29-1.504.202-1.65-.087-.145-.318-.231-.665-.405z"/>
      </svg>
    </a>

    <style>
      #wa-btn {
        position: fixed; bottom: 24px; right: 24px; z-index: 9000;
        width: 58px; height: 58px;
        display: flex; align-items: center; justify-content: center;
        background: #25D366; border-radius: 50%;
        box-shadow: 0 4px 20px rgba(37,211,102,0.45);
        text-decoration: none;
        transition: transform 240ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 240ms ease-out;
      }
      @media (hover: hover) and (pointer: fine) {
        #wa-btn:hover {
          transform: scale(1.12);
          box-shadow: 0 6px 28px rgba(37,211,102,0.55);
        }
      }
    </style>

    <script is:inline>
      /* Custom cursor */
      (function () {
        var cur = document.getElementById('mb-cursor');
        if (!cur) return;
        document.addEventListener('mousemove', function (e) {
          cur.style.left = e.clientX + 'px';
          cur.style.top  = e.clientY + 'px';
        });
        document.addEventListener('mousedown', function () { cur.classList.add('clicking'); });
        document.addEventListener('mouseup',   function () { cur.classList.remove('clicking'); });
        document.querySelectorAll('a,button,[role="button"]').forEach(function (el) {
          el.addEventListener('mouseenter', function () { cur.classList.add('hovering'); });
          el.addEventListener('mouseleave', function () { cur.classList.remove('hovering'); });
        });
      })();

      /* Scroll reveal via IntersectionObserver */
      (function () {
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '-12px 0px' });
        document.querySelectorAll('.reveal, .reveal-scale').forEach(function (el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>
