---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'MB-Solutions – Webdesign, IT-Services und Branding für KMU und Handwerksbetriebe in Köln.',
  ogImage = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1200&h=630&fit=crop&q=80&auto=format',
} = Astro.props;

const canonical = `https://www.mb-solutions.biz${Astro.url.pathname}`;
const fullTitle = `${title} | MB-Solutions`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Primary meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MB-Solutions" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />

    <!-- Resource hints -->
    <link rel="dns-prefetch" href="https://images.unsplash.com" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Page-specific head content (schema, preloads, etc.) -->
    <slot name="head" />
  </head>
  <body>
    <!-- Custom cursor (desktop only) -->
    <div id="mb-cursor" aria-hidden="true"></div>

    <!-- Skip link -->
    <a
      href="#main-content"
      style="position:absolute;left:-9999px;top:4px;z-index:10000;background:var(--accent);color:#fff;padding:8px 16px;border-radius:var(--r-md);font-size:14px;font-weight:600;text-decoration:none;"
      onfocus="this.style.left='4px'"
      onblur="this.style.left='-9999px'"
    >Zum Hauptinhalt springen</a>

    <slot />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/491718165966"
      target="_blank"
      rel="noopener noreferrer"
      id="wa-btn"
      aria-label="Per WhatsApp schreiben"
    >
      <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.103 1.524 5.829L.057 23.522a.5.5 0 0 0 .608.63l5.928-1.937A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.821 9.821 0 0 1-5.012-1.371l-.36-.214-3.724 1.218 1.244-3.617-.235-.372A9.818 9.818 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182S21.818 6.57 21.818 12 17.43 21.818 12 21.818z"/>
      </svg>
      <span class="wa-label">WhatsApp</span>
    </a>

    <style>
      #wa-btn {
        position: fixed; bottom: 24px; right: 24px; z-index: 9000;
        display: flex; align-items: center; gap: 8px;
        background: #25D366; color: white;
        border-radius: 50px; padding: 13px 13px;
        box-shadow: 0 4px 16px rgba(37,211,102,0.40);
        text-decoration: none;
        transition: transform 220ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 220ms ease-out, padding 220ms ease-out;
        overflow: hidden; max-width: 52px;
      }
      #wa-btn:hover {
        transform: scale(1.06);
        box-shadow: 0 6px 24px rgba(37,211,102,0.50);
        padding: 13px 18px;
        max-width: 180px;
      }
      .wa-label {
        font-family: 'Outfit', sans-serif; font-size: 14px; font-weight: 600;
        white-space: nowrap; opacity: 0; max-width: 0;
        transition: opacity 180ms ease-out 60ms, max-width 220ms ease-out;
        overflow: hidden;
      }
      #wa-btn:hover .wa-label { opacity: 1; max-width: 100px; }
    </style>

    <script is:inline>
      /* Custom cursor */
      (function () {
        var cur = document.getElementById('mb-cursor');
        if (!cur) return;
        document.addEventListener('mousemove', function (e) {
          cur.style.left = e.clientX + 'px';
          cur.style.top  = e.clientY + 'px';
        });
        document.addEventListener('mousedown', function () { cur.classList.add('clicking'); });
        document.addEventListener('mouseup',   function () { cur.classList.remove('clicking'); });
        document.querySelectorAll('a,button,[role="button"]').forEach(function (el) {
          el.addEventListener('mouseenter', function () { cur.classList.add('hovering'); });
          el.addEventListener('mouseleave', function () { cur.classList.remove('hovering'); });
        });
      })();

      /* Scroll reveal via IntersectionObserver */
      (function () {
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              obs.unobserve(e.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '-12px 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>
