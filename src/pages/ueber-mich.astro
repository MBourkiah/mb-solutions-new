---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';

const skills = [
  { label: 'Webdesign & Frontend', level: 90, color: 'var(--accent)' },
  { label: 'Astro / React / HTML+CSS', level: 88, color: 'var(--accent)' },
  { label: 'IT-Infrastruktur & Cloud', level: 80, color: '#16A34A' },
  { label: 'Branding & Grafikdesign', level: 75, color: '#D97706' },
  { label: 'SEO & Analytics', level: 72, color: 'var(--accent)' },
];

const timeline = [
  { year: '2019', title: 'Erste Kundenprojekte', body: 'Einstieg in die Selbstständigkeit mit einfachen WordPress-Websites für lokale Betriebe.' },
  { year: '2021', title: 'Full-Stack & IT', body: 'Erweiterung auf IT-Services: Microsoft 365, Cloud-Setups und Netzwerkinstallationen.' },
  { year: '2023', title: 'Gründung MB-Solutions', body: 'Formale Gründung als MB-Solutions mit Fokus auf Webdesign, IT und Branding aus einer Hand.' },
  { year: '2024', title: 'Modern Stack', body: 'Migration auf Astro und moderne Performance-Stacks für schnellere, skalierbare Websites.' },
];

const techStack = ['Astro', 'Next.js', 'WordPress', 'Microsoft 365', 'Figma', 'Tailwind CSS'];
---

<style>
  /* ── Hero ──────────────────────────────────────────────────── */
  .about-hero {
    background: var(--bg);
    min-height: 100dvh;
    display: flex; align-items: center;
    padding: 5rem 5% 3rem;
    position: relative; overflow: hidden;
  }
  .about-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(28,26,23,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .about-hero-inner {
    position: relative; z-index: 1;
    width: 100%; max-width: 80rem; margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 4rem; align-items: center;
  }

  /* Left text */
  .about-pill   { animation: fadeUp 500ms var(--ease-out) 60ms  both; }
  .about-h1-wrap { margin: 1.25rem 0; animation: fadeUp 650ms var(--ease-out) 130ms both; }
  .about-line {
    display: block;
    font-size: clamp(3.25rem, 6vw, 6rem);
    font-weight: 800; color: var(--text);
    letter-spacing: -0.04em; line-height: 0.96;
  }
  .about-line.accent { color: var(--accent); }
  .about-divider {
    width: 100%; height: 1px; background: var(--border-2);
    margin: 1.5rem 0; animation: fadeUp 500ms var(--ease-out) 220ms both;
  }
  .about-lead {
    font-size: 1rem; color: var(--text-2);
    line-height: 1.8; max-width: 44ch; margin: 0 0 2rem;
    animation: fadeUp 500ms var(--ease-out) 270ms both;
  }
  .about-ctas {
    display: flex; gap: 10px; flex-wrap: wrap;
    animation: fadeUp 500ms var(--ease-out) 330ms both;
  }
  .about-stats {
    display: flex; gap: 2rem; margin-top: 2rem;
    padding-top: 1.5rem; border-top: 1px solid var(--border);
    animation: fadeUp 500ms var(--ease-out) 400ms both; flex-wrap: wrap;
  }
  .stat-item { display: flex; flex-direction: column; gap: 3px; }
  .stat-val {
    font-family: 'Outfit', sans-serif; font-size: 1.75rem; font-weight: 800;
    color: var(--text); line-height: 1; letter-spacing: -0.03em;
  }
  .stat-label { font-size: 11px; color: var(--text-3); letter-spacing: 0.04em; text-transform: uppercase; font-weight: 500; }

  /* Right: Profile card */
  .about-portrait-wrap {
    animation: fadeUp 800ms var(--ease-out) 200ms both;
  }
  .about-profile-card {
    background: var(--surface);
    border: 1px solid var(--border-2);
    border-radius: var(--r-xl);
    padding: 1.75rem;
    box-shadow: var(--shadow-lg), 0 0 0 1px rgba(28,26,23,0.04);
    transform: rotate(1.5deg);
    transition: transform 400ms var(--ease-out), box-shadow 400ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .about-profile-card:hover {
      transform: rotate(0deg) scale(1.01);
      box-shadow: 0 24px 64px rgba(0,0,0,0.12), 0 0 0 1px rgba(28,26,23,0.04);
    }
  }
  .apc-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .apc-avatar {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--accent-light); border: 2px solid var(--border-a);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Outfit', sans-serif; font-size: 1.125rem; font-weight: 800;
    color: var(--accent); letter-spacing: -0.02em;
  }
  .apc-avail {
    display: inline-flex; align-items: center; gap: 6px;
    background: #F0FDF4; border: 1px solid #BBF7D0;
    border-radius: var(--r-full); padding: 5px 11px;
    font-size: 11px; font-weight: 600; color: #16A34A;
    font-family: 'Outfit', sans-serif;
  }
  .apc-avail-dot {
    width: 6px; height: 6px; border-radius: 50%; background: #22C55E;
    box-shadow: 0 0 0 2.5px rgba(34,197,94,0.25);
    animation: pulseDot 2.4s ease-in-out infinite;
    flex-shrink: 0;
  }
  .apc-name {
    font-family: 'Outfit', sans-serif; font-size: 1.0625rem; font-weight: 800;
    color: var(--text); letter-spacing: -0.03em; margin-bottom: 3px;
  }
  .apc-role { font-size: 0.8125rem; color: var(--text-2); margin-bottom: 10px; }
  .apc-location {
    display: flex; align-items: center; gap: 5px;
    font-size: 0.8125rem; color: var(--text-3); margin-bottom: 1.25rem;
  }
  .apc-divider { height: 1px; background: var(--border); margin-bottom: 1.25rem; }
  .apc-skills { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 1.25rem; }
  .apc-skill {
    font-size: 11px; font-weight: 500; color: var(--text-2);
    background: var(--bg-alt); border: 1px solid var(--border);
    padding: 3px 9px; border-radius: var(--r-full);
  }
  .apc-stats-row {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 1px; border-radius: var(--r-md); overflow: hidden;
    border: 1px solid var(--border);
  }
  .apc-stat-box {
    background: var(--bg-alt); padding: 12px 14px;
    display: flex; flex-direction: column; gap: 3px;
  }
  .apc-stat-val {
    font-family: 'Outfit', sans-serif; font-size: 1.25rem; font-weight: 800;
    color: var(--text); letter-spacing: -0.03em; line-height: 1;
  }
  .apc-stat-label { font-size: 10px; color: var(--text-3); letter-spacing: 0.06em; text-transform: uppercase; font-weight: 500; }

  /* Scroll indicator */
  .about-scroll {
    position: absolute; bottom: 24px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    color: var(--text-3); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    font-family: 'DM Sans', sans-serif; font-weight: 500;
    animation: fadeUp 600ms var(--ease-out) 900ms both;
  }
  .about-scroll svg { animation: scrollBounce 2.4s ease-in-out infinite; }
  @keyframes scrollBounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(5px); }
  }

  /* ── Skills section ────────────────────────────────────────── */
  .skills-section { background: var(--bg-alt); padding: 6rem 5%; }
  .skills-inner { max-width: 80rem; margin: 0 auto; }
  .skills-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; margin-top: 3rem; align-items: start; }
  .skills-intro { font-size: 1rem; color: var(--text-2); line-height: 1.8; }
  .skill-bars { display: flex; flex-direction: column; gap: 1.25rem; }
  .skill-row { display: flex; flex-direction: column; gap: 8px; }
  .skill-meta { display: flex; justify-content: space-between; align-items: baseline; }
  .skill-name { font-size: 0.875rem; font-weight: 500; color: var(--text); }
  .skill-pct { font-size: 0.8125rem; color: var(--text-3); }
  .skill-track { height: 5px; border-radius: var(--r-full); background: var(--border-2); overflow: hidden; }
  .skill-fill { height: 100%; border-radius: var(--r-full); }

  /* ── Timeline section ──────────────────────────────────────── */
  .timeline-section { background: var(--bg); padding: 6rem 5%; }
  .timeline-inner { max-width: 80rem; margin: 0 auto; }
  .timeline { display: flex; flex-direction: column; gap: 0; margin-top: 3rem; max-width: 700px; }
  .tl-item {
    display: grid; grid-template-columns: 80px 1fr;
    gap: 1.5rem; padding-bottom: 2rem; position: relative;
  }
  .tl-item:not(:last-child)::before {
    content: ''; position: absolute; left: 36px; top: 28px; bottom: 0;
    width: 1px; background: var(--border);
  }
  .tl-year {
    font-family: 'Outfit', sans-serif; font-size: 0.875rem; font-weight: 700; color: var(--accent);
    padding-top: 4px; display: flex; flex-direction: column; align-items: center; gap: 8px;
  }
  .tl-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--accent); border: 2px solid var(--bg);
    box-shadow: 0 0 0 3px rgba(127,119,221,0.20); flex-shrink: 0;
  }
  .tl-title { font-family: 'Outfit', sans-serif; font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 0.375rem; letter-spacing: -0.02em; }
  .tl-body { font-size: 0.9375rem; color: var(--text-2); line-height: 1.65; margin: 0; }

  .section-h2 {
    font-size: clamp(1.75rem, 2.75vw, 2.375rem); font-weight: 700;
    letter-spacing: -0.03em; color: var(--text); margin: 0 0 0.875rem; line-height: 1.2;
  }
  .section-sub { font-size: 1rem; color: var(--text-2); line-height: 1.7; max-width: 52ch; }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .about-hero { padding: 5rem 6% 4rem; }
    .about-hero-inner { grid-template-columns: 1fr; gap: 0; }
    .about-portrait-wrap { display: none; }
    .about-line { font-size: clamp(3rem, 11vw, 5rem); }
    .skills-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 599px) {
    .about-hero { padding: 5rem 5% 3rem; }
    .skills-section { padding: 4rem 5%; }
    .timeline-section { padding: 4rem 5%; }
    .about-line { font-size: clamp(2.75rem, 12vw, 4rem); }
    .about-lead { font-size: 0.9375rem; }
    .about-stats { gap: 1.5rem; }
  }
</style>

<BaseLayout
  title="Über mich – Maurice Bourkiah, Webdesigner Köln"
  description="Über Maurice Bourkiah von MB-Solutions – Freelancer für Webdesign, IT-Services und Branding in Köln."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>{JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://www.mb-solutions.biz" },
            { "@type": "ListItem", "position": 2, "name": "Über mich", "item": "https://www.mb-solutions.biz/ueber-mich" }
          ]
        },
        {
          "@type": "Person",
          "@id": "https://www.mb-solutions.biz/ueber-mich#person",
          "name": "Maurice Bourkiah",
          "givenName": "Maurice",
          "familyName": "Bourkiah",
          "jobTitle": "Freelancer – Webdesign, IT-Services & Branding",
          "description": "Freelancer aus Köln für Webdesign, IT-Services und Branding. Direktbetreuung für KMU und Handwerksbetriebe.",
          "url": "https://www.mb-solutions.biz/ueber-mich",
          "telephone": "+491718165966",
          "email": "mbourkiah@mb-solutions.biz",
          "worksFor": { "@id": "https://www.mb-solutions.biz/#business" },
          "address": { "@type": "PostalAddress", "addressLocality": "Köln", "addressCountry": "DE" },
          "knowsAbout": ["Webdesign", "Frontend-Entwicklung", "IT-Infrastruktur", "Branding", "SEO", "Astro", "Next.js", "React"]
        }
      ]
    })}</script>
  </Fragment>

  <Navbar />
  <main id="main-content">

    <!-- Hero -->
    <section class="about-hero" aria-labelledby="about-heading">
      <div class="about-hero-inner">

        <!-- Left: Text -->
        <div>
          <div class="about-pill">
            <span class="pill">
              <span class="pill-dot" aria-hidden="true"></span>
              Verfügbar für neue Projekte
            </span>
          </div>

          <div class="about-h1-wrap">
            <span class="about-line">Hallo, ich</span>
            <span class="about-line accent">bin Maurice.</span>
          </div>

          <div class="about-divider" aria-hidden="true"></div>

          <p class="about-lead" id="about-heading">
            Freelancer aus Köln mit einem Ding für schöne Websites,
            sauber aufgesetzte IT und Marken, die im Gedächtnis bleiben.
            Ich arbeite direkt mit meinen Kunden — kein Mittelmann, keine Warteschlange.
          </p>

          <div class="about-ctas">
            <a href="/kontakt" class="btn-primary">Zusammenarbeiten</a>
            <a href="/portfolio" class="btn-outline">
              Portfolio ansehen
              <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
                <path d="M2.5 10.5L10.5 2.5M10.5 2.5H5M10.5 2.5V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <div class="about-stats" aria-label="Kennzahlen">
            <div class="stat-item"><span class="stat-val">5+</span><span class="stat-label">Jahre Erfahrung</span></div>
            <div class="stat-item"><span class="stat-val">12+</span><span class="stat-label">Projekte</span></div>
            <div class="stat-item"><span class="stat-val">100%</span><span class="stat-label">Direktbetreuung</span></div>
          </div>
        </div>

        <!-- Right: Profile card -->
        <div class="about-portrait-wrap" aria-hidden="true">
          <div class="about-profile-card">
            <div class="apc-header">
              <div class="apc-avatar">MB</div>
              <span class="apc-avail">
                <span class="apc-avail-dot"></span>
                Verfügbar
              </span>
            </div>

            <div class="apc-name">Maurice Bourkiah</div>
            <div class="apc-role">Webdesign · IT-Services · Branding</div>

            <div class="apc-location">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
              Köln, Deutschland
            </div>

            <div class="apc-divider"></div>

            <div class="apc-skills">
              {techStack.map(t => <span class="apc-skill">{t}</span>)}
            </div>

            <div class="apc-stats-row">
              <div class="apc-stat-box">
                <span class="apc-stat-val">5+</span>
                <span class="apc-stat-label">Jahre</span>
              </div>
              <div class="apc-stat-box">
                <span class="apc-stat-val">12+</span>
                <span class="apc-stat-label">Projekte</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Scroll indicator -->
      <div class="about-scroll" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
          <path d="M4 6.5L9 11.5L14 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </section>

    <!-- Skills -->
    <section class="skills-section" aria-labelledby="skills-heading">
      <div class="skills-inner">
        <div class="eyebrow reveal">
          <span class="eyebrow-bar" aria-hidden="true"></span>
          Kenntnisse
        </div>
        <h2 class="section-h2 reveal" id="skills-heading">Was ich mitbringe.</h2>
        <div class="skills-grid">
          <p class="skills-intro reveal">
            Ich bin kein Spezialist in einer Nische — ich verstehe das Ganze.
            Vom Design über den Code bis zur IT-Infrastruktur denke ich vernetzt
            und liefere Lösungen, die langfristig funktionieren.
          </p>
          <div class="skill-bars">
            {skills.map(s => (
              <div class="skill-row reveal">
                <div class="skill-meta">
                  <span class="skill-name">{s.label}</span>
                  <span class="skill-pct">{s.level}%</span>
                </div>
                <div class="skill-track">
                  <div
                    class="skill-fill"
                    style={`width:${s.level}%;background:${s.color};`}
                    role="progressbar"
                    aria-valuenow={s.level}
                    aria-valuemin={0}
                    aria-valuemax={100}
                    aria-label={s.label}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline-section" aria-labelledby="timeline-heading">
      <div class="timeline-inner">
        <div class="eyebrow reveal">
          <span class="eyebrow-bar" aria-hidden="true"></span>
          Werdegang
        </div>
        <h2 class="section-h2 reveal" id="timeline-heading">Wie es dazu kam.</h2>
        <p class="section-sub reveal">Von den ersten Projekten bis zur eigenen Agentur.</p>
        <div class="timeline">
          {timeline.map(item => (
            <div class="tl-item reveal">
              <div class="tl-year">
                <span class="tl-dot" aria-hidden="true"></span>
                {item.year}
              </div>
              <div>
                <p class="tl-title">{item.title}</p>
                <p class="tl-body">{item.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTASection />
  </main>
  <Footer />
</BaseLayout>
