---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const webdesignFeatures = [
  'Responsives Design (Mobile-first)',
  'Optimiert für Google (SEO)',
  'Schnelle Ladezeiten (Core Web Vitals)',
  'Moderne Technologien (Astro, Webflow)',
  'Inkl. Kontaktformular & Impressum',
];

const itFeatures = [
  'Hardware & Software Einrichtung',
  'Cloud-Setup (Google Workspace, Microsoft 365)',
  'Netzwerk & WLAN Konfiguration',
  'Datensicherung & Backup-Lösungen',
  'Laufender IT-Support per Retainer',
];

const brandingFeatures = [
  'Logo-Design (3 Entwürfe zur Auswahl)',
  'Visitenkarten & Briefpapier',
  'Corporate Design Guide',
  'Social Media Kit',
  'Druckfertige Dateien (PDF, PNG, SVG)',
];
---

<BaseLayout
  title="Leistungen | MB-Solutions Köln"
  description="Webdesign, IT-Services und Branding aus Köln – alles aus einer Hand."
>
  <Navbar />

  <main class="flex-1">

    <!-- Hero -->
    <section class="bg-gray-50 py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-primary font-medium tracking-wide uppercase text-sm mb-3">Leistungen</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Was ich für dich tue.</h1>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
          Drei Kernleistungen, die sich perfekt ergänzen – du bekommst alles aus einer Hand,
          ohne Koordinationsaufwand.
        </p>
      </div>
    </section>

    <!-- Webdesign -->
    <section class="bg-white py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

          <!-- Text -->
          <div>
            <p class="text-primary font-medium tracking-wide uppercase text-xs mb-3">01</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-5">Webdesign</h2>
            <p class="text-gray-500 leading-relaxed mb-6">
              Eine Webseite ist deine wichtigste Verkaufsfläche – sie arbeitet 24/7 für dich.
              Ich baue Seiten, die nicht nur schön aussehen, sondern auch gefunden werden
              und konvertieren.
            </p>
            <div class="inline-block bg-primary/5 border border-primary/15 rounded-2xl px-6 py-4 mb-8">
              <p class="text-3xl font-bold text-primary">ab 499 €</p>
              <p class="text-sm text-gray-500 mt-0.5">Einmalzahlung, kein Abo</p>
            </div>
            <div>
              <a
                href="/kontakt"
                class="inline-flex items-center px-6 py-3 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-dark transition-colors"
              >
                Webseite anfragen →
              </a>
            </div>
          </div>

          <!-- Feature List -->
          <div class="bg-gray-50 rounded-2xl p-8">
            <p class="text-sm font-semibold text-gray-900 mb-5">Das ist dabei:</p>
            <ul class="space-y-4">
              {webdesignFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-primary/10 shrink-0">
                    <svg class="w-3 h-3 text-primary" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 6l3 3 5-5" />
                    </svg>
                  </span>
                  <span class="text-gray-700 text-sm">{f}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- IT-Services -->
    <section class="bg-gray-50 py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

          <!-- Feature List (links auf Desktop) -->
          <div class="bg-white rounded-2xl p-8 order-2 lg:order-1">
            <p class="text-sm font-semibold text-gray-900 mb-5">Das ist dabei:</p>
            <ul class="space-y-4">
              {itFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-emerald-100 shrink-0">
                    <svg class="w-3 h-3 text-emerald-600" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 6l3 3 5-5" />
                    </svg>
                  </span>
                  <span class="text-gray-700 text-sm">{f}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Text (rechts auf Desktop) -->
          <div class="order-1 lg:order-2">
            <p class="text-emerald-600 font-medium tracking-wide uppercase text-xs mb-3">02</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-5">IT-Services</h2>
            <p class="text-gray-500 leading-relaxed mb-6">
              Technik soll funktionieren – nicht nerven. Ich kümmere mich um Setup, Wartung
              und Support, damit du dich auf dein Business konzentrieren kannst.
            </p>
            <div class="inline-block bg-emerald-50 border border-emerald-100 rounded-2xl px-6 py-4 mb-8">
              <p class="text-3xl font-bold text-emerald-700">ab 45 €/Std.</p>
              <p class="text-sm text-gray-500 mt-0.5">oder Flatrate auf Anfrage</p>
            </div>
            <div>
              <a
                href="/kontakt"
                class="inline-flex items-center px-6 py-3 rounded-xl bg-emerald-600 text-white text-sm font-semibold hover:bg-emerald-700 transition-colors"
              >
                IT-Support anfragen →
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Branding -->
    <section class="bg-white py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

          <!-- Text -->
          <div>
            <p class="text-orange-600 font-medium tracking-wide uppercase text-xs mb-3">03</p>
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-5">Branding & Marketing</h2>
            <p class="text-gray-500 leading-relaxed mb-6">
              Deine Marke ist der erste Eindruck – und der zählt. Ich entwickle visuelle
              Identitäten, die professionell wirken und zu deinem Business passen.
            </p>
            <div class="inline-block bg-orange-50 border border-orange-100 rounded-2xl px-6 py-4 mb-8">
              <p class="text-3xl font-bold text-orange-700">ab 149 €</p>
              <p class="text-sm text-gray-500 mt-0.5">Logo-Paket, Einmalzahlung</p>
            </div>
            <div>
              <a
                href="/kontakt"
                class="inline-flex items-center px-6 py-3 rounded-xl bg-orange-600 text-white text-sm font-semibold hover:bg-orange-700 transition-colors"
              >
                Branding anfragen →
              </a>
            </div>
          </div>

          <!-- Feature List -->
          <div class="bg-gray-50 rounded-2xl p-8">
            <p class="text-sm font-semibold text-gray-900 mb-5">Das ist dabei:</p>
            <ul class="space-y-4">
              {brandingFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-orange-100 shrink-0">
                    <svg class="w-3 h-3 text-orange-600" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M2 6l3 3 5-5" />
                    </svg>
                  </span>
                  <span class="text-gray-700 text-sm">{f}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="bg-primary py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
          Noch nicht sicher, welche Leistung du brauchst?
        </h2>
        <p class="text-white/75 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
          Im kostenlosen Erstgespräch finden wir gemeinsam heraus, was für dich Sinn macht.
        </p>
        <a
          href="/kontakt"
          class="inline-flex items-center px-7 py-3.5 rounded-xl bg-white text-primary font-semibold hover:bg-gray-50 transition-colors"
        >
          Kostenloses Erstgespräch
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
