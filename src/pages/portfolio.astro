---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    title: 'Café Rösterei Köln',
    description: 'Komplette Website + Corporate Identity für eine Kölner Spezialitätenrösterei.',
    tags: ['Webdesign', 'Branding'],
    colorBlock: 'bg-primary/20',
  },
  {
    title: 'Elektro Müller GmbH',
    description: 'Website, Logo & lokale IT-Einrichtung für einen Elektrofachbetrieb.',
    tags: ['Webdesign', 'IT-Setup'],
    colorBlock: 'bg-teal',
  },
  {
    title: 'Fitnessstudio NordKöln',
    description: 'Logo, Visitenkarten & Social Media Kit für ein modernes Fitnessstudio.',
    tags: ['Branding', 'Social Media'],
    colorBlock: 'bg-coral',
  },
  {
    title: 'Steuerberatung Hofmann',
    description: 'Cloud-Migration auf Google Workspace & laufender IT-Support-Retainer.',
    tags: ['IT-Services'],
    colorBlock: 'bg-primary/10',
  },
  {
    title: 'Zahnarzt Praxis Köln-Süd',
    description: 'Moderne Praxis-Website mit Online-Terminbuchung und Patienten-Portal.',
    tags: ['Webdesign'],
    colorBlock: 'bg-teal/60',
  },
  {
    title: 'Immobilien Weber',
    description: 'Website + vollständige Brand Identity für ein regionalen Makler.',
    tags: ['Webdesign', 'Branding'],
    colorBlock: 'bg-coral/60',
  },
] as const;

const filters = ['Alle', 'Webdesign', 'Branding', 'IT-Services'];
---

<BaseLayout
  title="Portfolio | MB-Solutions Köln"
  description="Webdesign und Branding Projekte von MB-Solutions aus Köln."
>
  <Navbar />

  <main class="flex-1">

    <!-- Hero -->
    <section class="bg-gray-50 py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-primary font-medium tracking-wide uppercase text-sm mb-3">Portfolio</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
          Projekte, die für sich sprechen.
        </h1>
        <p class="text-lg text-gray-500 leading-relaxed max-w-2xl mx-auto">
          Jedes Projekt ist ein Vertrauensbeweis – hier siehst du, wie ich anderen
          Unternehmen geholfen habe.
        </p>
      </div>
    </section>

    <!-- Projects -->
    <section class="bg-white py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Filter Buttons -->
        <div class="flex flex-wrap gap-2 justify-center mb-14" role="group" aria-label="Projekte filtern">
          {filters.map((filter, i) => (
            <button
              type="button"
              class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${
                i === 0
                  ? 'bg-primary text-white'
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
              }`}
            >
              {filter}
            </button>
          ))}
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((project) => (
            <div class="group rounded-2xl overflow-hidden bg-white border border-gray-100 hover:shadow-lg transition-all duration-200">

              <!-- Color Block -->
              <div class={`h-52 w-full ${project.colorBlock}`}></div>

              <!-- Card Content -->
              <div class="p-6">
                <div class="flex flex-wrap gap-1.5 mb-3">
                  {project.tags.map((tag) => (
                    <span class="inline-block px-2.5 py-0.5 rounded-full bg-gray-100 text-gray-500 text-xs font-medium">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="text-base font-semibold text-gray-900 mb-1.5">
                  {project.title}
                </h3>
                <p class="text-sm text-gray-500 leading-relaxed">
                  {project.description}
                </p>
              </div>

            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          Du willst auch so ein Ergebnis?
        </h2>
        <a
          href="/kontakt"
          class="inline-flex items-center px-7 py-3.5 rounded-xl bg-primary text-white font-semibold hover:bg-primary-dark transition-colors"
        >
          Projekt anfragen →
        </a>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
