---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    gradient: 'linear-gradient(135deg, rgba(127,119,221,0.28) 0%, rgba(127,119,221,0.04) 100%)',
    accentColor: '#AFA9EC',
    tags: ['Webdesign', 'Branding'],
    title: 'Café Rösterei Köln',
    description: 'Komplette Website + Corporate Identity für eine Kölner Spezialitätenrösterei.',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(45,212,191,0.22) 0%, rgba(45,212,191,0.03) 100%)',
    accentColor: '#2DD4BF',
    tags: ['Webdesign', 'IT-Setup'],
    title: 'Elektro Müller GmbH',
    description: 'Website, Logo & lokale IT-Einrichtung für einen Elektrofachbetrieb.',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(255,140,107,0.22) 0%, rgba(255,140,107,0.03) 100%)',
    accentColor: '#FF8C6B',
    tags: ['Branding'],
    title: 'Fitnessstudio NordKöln',
    description: 'Logo, Visitenkarten & Social Media Kit für ein modernes Fitnessstudio.',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(127,119,221,0.14) 0%, rgba(10,10,15,0) 100%)',
    accentColor: '#AFA9EC',
    tags: ['IT-Services'],
    title: 'Steuerberatung Hofmann',
    description: 'Cloud-Migration auf Google Workspace & laufender IT-Support-Retainer.',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(45,212,191,0.18) 0%, rgba(45,212,191,0.02) 100%)',
    accentColor: '#2DD4BF',
    tags: ['Webdesign'],
    title: 'Zahnarzt Praxis Köln-Süd',
    description: 'Moderne Praxis-Website mit Online-Terminbuchung und Patienten-Portal.',
  },
  {
    gradient: 'linear-gradient(135deg, rgba(255,140,107,0.18) 0%, rgba(255,140,107,0.02) 100%)',
    accentColor: '#FF8C6B',
    tags: ['Webdesign', 'Branding'],
    title: 'Immobilien Weber',
    description: 'Website + vollständige Brand Identity für einen regionalen Makler.',
  },
] as const;

const filters = ['Alle', 'Webdesign', 'Branding', 'IT-Services'];
---

<style>
  .pf-card {
    background: #13131f;
    border: 1px solid rgba(127,119,221,0.1);
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 250ms, transform 250ms, box-shadow 250ms;
  }
  .pf-card:hover {
    border-color: rgba(127,119,221,0.28);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
  }
  .pf-preview {
    height: 200px;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    gap: 4px;
    flex-wrap: wrap;
  }
  .pf-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(rgba(240,239,255,0.05) 1px, transparent 1px);
    background-size: 22px 22px;
  }
  .pf-tag {
    position: relative;
    font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 4px 10px; border-radius: 100px;
    background: rgba(10,10,15,0.55); backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .pf-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) { .pf-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 580px) { .pf-grid { grid-template-columns: 1fr; } }
</style>

<BaseLayout
  title="Portfolio | MB-Solutions Köln"
  description="Webdesign und Branding Projekte von MB-Solutions aus Köln."
>
  <Navbar />
  <main style="flex:1;">

    <!-- Hero -->
    <section style="background:#0d0d18; padding:6rem 0 5rem; text-align:center;">
      <div style="max-width:72rem; margin:0 auto; padding:0 2rem;">
        <div style="width:36px; height:2px; background:#7F77DD; margin:0 auto 1.5rem;"></div>
        <p style="font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:rgba(240,239,255,0.3); margin-bottom:1rem;">Portfolio</p>
        <h1 style="font-size:clamp(2.25rem,4vw,3.5rem); font-weight:700; color:#F0EFFF; line-height:1.1; margin:0 0 1.25rem;">
          Projekte, die für sich sprechen.
        </h1>
        <p style="font-size:1.0625rem; color:rgba(240,239,255,0.5); line-height:1.75; max-width:520px; margin:0 auto;">
          Jedes Projekt ist ein Vertrauensbeweis – hier siehst du, wie ich anderen Unternehmen geholfen habe.
        </p>
      </div>
    </section>

    <!-- Projects -->
    <section style="background:#0a0a0f; padding:5rem 0 7rem;">
      <div style="max-width:72rem; margin:0 auto; padding:0 2rem;">

        <div style="display:flex; flex-wrap:wrap; gap:8px; justify-content:center; margin-bottom:3.5rem;" role="group" aria-label="Projekte filtern">
          {filters.map((filter, i) => (
            <button type="button" style={`padding:8px 20px; border-radius:100px; font-size:13px; font-weight:500; border:none; cursor:pointer; font-family:inherit; ${i === 0 ? 'background:#7F77DD; color:white;' : 'background:rgba(127,119,221,0.1); color:rgba(240,239,255,0.5);'}`}>
              {filter}
            </button>
          ))}
        </div>

        <div class="pf-grid">
          {projects.map((p) => (
            <div class="pf-card">
              <div class="pf-preview" style={`background:${p.gradient};`}>
                <div class="pf-dots" aria-hidden="true"></div>
                {p.tags.map((tag) => (
                  <span class="pf-tag" style={`color:${p.accentColor};`}>{tag}</span>
                ))}
              </div>
              <div style="padding:1.5rem;">
                <h3 style="font-size:1rem; font-weight:600; color:#F0EFFF; margin:0 0 0.5rem;">{p.title}</h3>
                <p style="font-size:13px; color:rgba(240,239,255,0.4); line-height:1.65;">{p.description}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- CTA -->
    <section style="background:#0d0d18; padding:5rem 0; text-align:center;">
      <div style="max-width:72rem; margin:0 auto; padding:0 2rem;">
        <h2 style="font-size:clamp(1.75rem,3vw,2.5rem); font-weight:700; color:#F0EFFF; margin:0 0 2rem;">
          Du willst auch so ein Ergebnis?
        </h2>
        <a href="/kontakt" style="display:inline-flex; align-items:center; padding:14px 32px; border-radius:100px; background:#7F77DD; color:white; font-size:15px; font-weight:600; text-decoration:none;">
          Projekt anfragen →
        </a>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>
