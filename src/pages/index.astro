---
import BaseLayout from '../layouts/BaseLayout.astro';

import Navbar from '../components/Navbar.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import PortfolioSection from '../components/PortfolioSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import AboutSection from '../components/AboutSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<style>
  .mobile-stats-strip {
    display: none;
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 6%;
    justify-content: center;
    align-items: center;
    gap: 0;
  }
  .ms-divider { width: 1px; background: var(--border); height: 2rem; margin: 0 2rem; }
  .ms-stat { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .ms-val {
    font-family: 'Outfit', sans-serif; font-size: 1.375rem; font-weight: 700;
    color: var(--text); letter-spacing: -0.03em; line-height: 1;
  }
  .ms-label { font-size: 10px; color: var(--text-3); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }

  @media (max-width: 900px) { .mobile-stats-strip { display: flex; } }
</style>

<BaseLayout
  title="Webdesign & IT-Services für KMU in Köln"
  description="MB-Solutions – Ihr Partner für Webdesign, IT-Services und Branding in Köln. Professionelle digitale Lösungen für KMU und Handwerksbetriebe."
>
  <Fragment slot="head">
    <link rel="preload" as="image" href="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=720&h=460&fit=crop&q=82&auto=format" />
    <script type="application/ld+json" is:inline>{JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "ProfessionalService",
          "@id": "https://www.mb-solutions.biz/#business",
          "name": "MB-Solutions",
          "alternateName": "MB Solutions Köln",
          "description": "Webdesign, IT-Services und Branding für KMU und Handwerksbetriebe in Köln. Direktbetreuung durch Maurice Bourkiah.",
          "url": "https://www.mb-solutions.biz",
          "telephone": "+491718165966",
          "email": "mbourkiah@mb-solutions.biz",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Auf der Bitze 18",
            "addressLocality": "Köln",
            "postalCode": "51107",
            "addressCountry": "DE"
          },
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 50.9333,
            "longitude": 6.9500
          },
          "areaServed": { "@type": "City", "name": "Köln" },
          "openingHoursSpecification": [{
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
            "opens": "09:00",
            "closes": "18:00"
          }],
          "priceRange": "€€",
          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Leistungen",
            "itemListElement": [
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Webdesign & Entwicklung" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "IT-Services & Cloud-Setup" } },
              { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Branding & Corporate Identity" } }
            ]
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://www.mb-solutions.biz/#website",
          "url": "https://www.mb-solutions.biz",
          "name": "MB-Solutions",
          "description": "Webdesign, IT-Services und Branding für KMU in Köln",
          "publisher": { "@id": "https://www.mb-solutions.biz/#business" },
          "inLanguage": "de-DE"
        }
      ]
    })}</script>
  </Fragment>
  <Navbar />
  <main>
    <HeroSection />

    <!-- Stats strip: only visible on mobile (hero-stats is hidden there) -->
    <div class="mobile-stats-strip" aria-label="Kennzahlen">
      <div class="ms-stat"><span class="ms-val">12+</span><span class="ms-label">Projekte</span></div>
      <div class="ms-divider" aria-hidden="true"></div>
      <div class="ms-stat"><span class="ms-val">48h</span><span class="ms-label">Antwortzeit</span></div>
      <div class="ms-divider" aria-hidden="true"></div>
      <div class="ms-stat"><span class="ms-val">5+</span><span class="ms-label">Jahre Erfahrung</span></div>
    </div>

    <!-- Marquee strip -->
    <div class="marquee-outer" aria-hidden="true">
      <div class="marquee-inner">
        {Array.from({length: 2}).map(() => (
          <>
            <span class="marquee-word">Webdesign</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">IT-Services</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">Branding</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">Köln</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">KMU</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">Direktbetreuung</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">Corporate Identity</span>
            <span class="marquee-sep">·</span>
            <span class="marquee-word">Next.js</span>
            <span class="marquee-sep">·</span>
          </>
        ))}
      </div>
    </div>

    <ServicesSection />
    <ProcessSection />
    <PortfolioSection />
    <TestimonialsSection />
    <AboutSection />
    <FAQSection />
    <CTASection />
  </main>
  <Footer />
</BaseLayout>
