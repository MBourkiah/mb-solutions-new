---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<style>
  .kontakt-section { background: var(--bg); padding: 7rem 5% 6rem; flex: 1; }
  .kontakt-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: start;
    max-width: 80rem; margin: 0 auto;
  }
  .kontakt-h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.5rem); font-weight: 800;
    letter-spacing: -0.035em; color: var(--text); line-height: 1.1; margin: 0 0 1.25rem;
  }
  .kontakt-sub { font-size: 1.0625rem; color: var(--text-2); line-height: 1.75; max-width: 44ch; margin: 0 0 2.5rem; }

  .contact-info { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2.5rem; }
  .ci-item {
    display: flex; align-items: center; gap: 12px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-md); padding: 14px 16px; text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: border-color 180ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) { .ci-item:hover { border-color: var(--border-a); } }
  .ci-icon {
    width: 38px; height: 38px; border-radius: var(--r-sm);
    background: var(--accent-light); display: flex; align-items: center; justify-content: center;
    color: var(--accent); flex-shrink: 0;
  }
  .ci-label { font-size: 11px; color: var(--text-3); font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; }
  .ci-value { font-size: 0.9375rem; color: var(--text); }

  .promise-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);
  }
  .promise-title { font-family: 'Outfit', sans-serif; font-size: 0.9375rem; font-weight: 700; color: var(--text); margin: 0 0 1rem; letter-spacing: -0.02em; }
  .promise-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
  .promise-list li { display: flex; align-items: center; gap: 9px; font-size: 0.875rem; color: var(--text-2); }
  .promise-list li svg { flex-shrink: 0; color: var(--accent); }

  @media (max-width: 860px) { .kontakt-grid { grid-template-columns: 1fr; gap: 3rem; } }
</style>

<BaseLayout
  title="Kontakt – MB-Solutions Köln"
  description="Kontaktiere MB-Solutions für Webdesign, IT-Services und Branding in Köln. Kostenloses Erstgespräch vereinbaren."
>
  <Navbar />
  <main id="main-content" style="display:flex;flex-direction:column;flex:1;">
    <section class="kontakt-section" aria-labelledby="kontakt-heading">
      <div class="kontakt-grid">

        <div>
          <div class="eyebrow reveal">
            <span class="eyebrow-bar" aria-hidden="true"></span>
            Kontakt
          </div>
          <h1 class="kontakt-h1 reveal" id="kontakt-heading">Lass uns reden.</h1>
          <p class="kontakt-sub reveal">
            Schreib mir eine Nachricht oder melde dich direkt per E-Mail.
            Ich melde mich innerhalb von 48 Stunden zurück.
          </p>

          <div class="contact-info reveal">
            <a href="mailto:hallo@mb-solutions.biz" class="ci-item">
              <div class="ci-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
              </div>
              <div>
                <div class="ci-label">E-Mail</div>
                <div class="ci-value">hallo@mb-solutions.biz</div>
              </div>
            </a>
            <div class="ci-item">
              <div class="ci-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <div class="ci-label">Standort</div>
                <div class="ci-value">Köln, Deutschland</div>
              </div>
            </div>
            <div class="ci-item">
              <div class="ci-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <div class="ci-label">Antwortzeit</div>
                <div class="ci-value">Innerhalb von 48 Stunden</div>
              </div>
            </div>
          </div>

          <div class="promise-card reveal">
            <p class="promise-title">Was dich erwartet</p>
            <ul class="promise-list">
              {[
                'Kostenlose Erstberatung ohne Verkaufsdruck',
                'Klares Angebot mit transparenten Preisen',
                'Du sprichst direkt mit dem Entwickler',
                'Persönliche Treffen in Köln möglich',
              ].map(item => (
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2.5 7.5L5.5 10.5L11.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="reveal">
          <ContactForm />
        </div>

      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
