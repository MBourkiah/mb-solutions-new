---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<style>
  /* ── Hero / Main section ───────────────────────────────────── */
  .kontakt-section {
    background: var(--bg);
    min-height: 100dvh;
    padding: max(7rem, 13vh) 5% 5rem;
    position: relative;
  }
  .kontakt-section::before {
    content: '';
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(28,26,23,0.06) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .kontakt-inner {
    position: relative; z-index: 1;
    max-width: 80rem; margin: 0 auto;
  }
  .kontakt-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 5rem; align-items: start;
  }

  /* Left: heading + info */
  .kt-pill   { animation: fadeUp 500ms var(--ease-out) 60ms  both; }
  .kt-h1-wrap { margin: 1.25rem 0; animation: fadeUp 650ms var(--ease-out) 130ms both; }
  .kt-line {
    display: block;
    font-size: clamp(3rem, 5.5vw, 5.5rem);
    font-weight: 800; color: var(--text);
    letter-spacing: -0.04em; line-height: 0.96;
  }
  .kt-line.accent { color: var(--accent); }
  .kt-divider {
    width: 100%; height: 1px; background: var(--border-2);
    margin: 1.5rem 0; animation: fadeUp 500ms var(--ease-out) 220ms both;
  }
  .kontakt-sub {
    font-size: 1.0625rem; color: var(--text-2); line-height: 1.75;
    max-width: 44ch; margin: 0 0 2.5rem;
    animation: fadeUp 500ms var(--ease-out) 270ms both;
  }

  .contact-info {
    display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;
    animation: fadeUp 500ms var(--ease-out) 330ms both;
  }
  .ci-item {
    display: flex; align-items: center; gap: 12px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-md); padding: 14px 16px; text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: border-color 180ms var(--ease-out), transform 180ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .ci-item:hover { border-color: var(--border-a); transform: translateX(3px); }
  }
  .ci-icon {
    width: 38px; height: 38px; border-radius: var(--r-sm);
    background: var(--accent-light); display: flex; align-items: center; justify-content: center;
    color: var(--accent); flex-shrink: 0;
  }
  .ci-label { font-size: 11px; color: var(--text-3); font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; }
  .ci-value { font-size: 0.9375rem; color: var(--text); }

  .promise-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--r-lg); padding: 1.5rem; box-shadow: var(--shadow-sm);
    animation: fadeUp 500ms var(--ease-out) 400ms both;
  }
  .promise-title { font-family: 'Outfit', sans-serif; font-size: 0.9375rem; font-weight: 700; color: var(--text); margin: 0 0 1rem; letter-spacing: -0.02em; }
  .promise-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 9px; }
  .promise-list li { display: flex; align-items: center; gap: 9px; font-size: 0.875rem; color: var(--text-2); }
  .promise-list li svg { flex-shrink: 0; color: var(--accent); }

  /* Right: Form */
  .kt-form-col { animation: fadeUp 700ms var(--ease-out) 300ms both; }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 860px) {
    .kontakt-grid { grid-template-columns: 1fr; gap: 3rem; }
    .kt-line { font-size: clamp(2.75rem, 10vw, 4.5rem); }
  }
  @media (max-width: 599px) {
    .kontakt-section { padding: 5rem 5% 4rem; }
    .contact-info { gap: 10px; }
    .ci-item { padding: 12px 14px; }
    .kt-line { font-size: clamp(2.5rem, 12vw, 4rem); }
    .kontakt-sub { font-size: 0.9375rem; }
  }
</style>

<BaseLayout
  title="Kontakt – MB-Solutions Köln"
  description="Kontaktiere MB-Solutions für Webdesign, IT-Services und Branding in Köln. Kostenloses Erstgespräch vereinbaren."
>
  <Navbar />
  <main id="main-content">
    <section class="kontakt-section" aria-labelledby="kontakt-heading">
      <div class="kontakt-inner">
        <div class="kontakt-grid">

          <!-- Left: Info -->
          <div>
            <div class="kt-pill">
              <span class="pill">
                <span class="pill-dot" aria-hidden="true"></span>
                Kostenloser Erstkontakt
              </span>
            </div>

            <div class="kt-h1-wrap">
              <span class="kt-line" id="kontakt-heading">Lass uns</span>
              <span class="kt-line accent">reden.</span>
            </div>

            <div class="kt-divider" aria-hidden="true"></div>

            <p class="kontakt-sub">
              Schreib mir eine Nachricht oder ruf direkt an.
              Ich melde mich innerhalb von 24 Stunden zurück.
            </p>

            <div class="contact-info">
              <a href="tel:+491718165966" class="ci-item">
                <div class="ci-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.72 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.63 1.22h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.84a16 16 0 0 0 6.29 6.29l1.8-1.8a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7a2 2 0 0 1 1.72 2.04z"/>
                  </svg>
                </div>
                <div>
                  <div class="ci-label">Telefon</div>
                  <div class="ci-value">+49 171 816 59 66</div>
                </div>
              </a>
              <a href="mailto:mbourkiah@mb-solutions.biz" class="ci-item">
                <div class="ci-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                </div>
                <div>
                  <div class="ci-label">E-Mail</div>
                  <div class="ci-value">mbourkiah@mb-solutions.biz</div>
                </div>
              </a>
              <div class="ci-item">
                <div class="ci-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <div class="ci-label">Standort</div>
                  <div class="ci-value">Köln, Deutschland</div>
                </div>
              </div>
              <div class="ci-item">
                <div class="ci-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                </div>
                <div>
                  <div class="ci-label">Antwortzeit</div>
                  <div class="ci-value">Innerhalb von 24–48 Stunden</div>
                </div>
              </div>
            </div>

            <div class="promise-card">
              <p class="promise-title">Was dich erwartet</p>
              <ul class="promise-list">
                {[
                  'Kostenlose Erstberatung ohne Verkaufsdruck',
                  'Klares Angebot mit transparenten Preisen',
                  'Du sprichst direkt mit dem Entwickler',
                  'Persönliche Treffen in Köln möglich',
                ].map(item => (
                  <li>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                      <path d="M2.5 7.5L5.5 10.5L11.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Right: Form -->
          <div class="kt-form-col">
            <ContactForm />
          </div>

        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
